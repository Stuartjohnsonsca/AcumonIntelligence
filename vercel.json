{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --skip-generate --accept-data-loss && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["lhr1"],
  "functions": {
    "app/api/resource-planning/optimize/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup-xero",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-extraction",
      "schedule": "0 3 * * *"
    }
  ]
}
