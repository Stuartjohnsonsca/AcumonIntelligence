{
  "framework": "nextjs",
  "buildCommand": "prisma db push --skip-generate && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/cleanup-xero",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-extraction",
      "schedule": "0 3 * * *"
    }
  ]
}
