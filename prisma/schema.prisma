// ─── Bank to TB Tool ────────────────────────────────────────────────────────

model BankToTBSession {
  id                    String   @id @default(uuid())
  clientId              String   @map("client_id")
  periodId              String   @map("period_id")
  userId                String   @map("user_id")
  firmId                String   @map("firm_id")
  status                String   @default("active") // active | complete | archived
  openingPositionSource String?  @map("opening_position_source") // firm_standard | upload | paste | prior_period
  openingPositionData   Json?    @map("opening_position_data")
  combineMode           String?  @map("combine_mode") // together | separate
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period       ClientPeriod        @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id])
  files        BankToTBFile[]
  accounts     BankAccount[]
  transactions BankTransaction[]
  trialBalance TrialBalanceEntry[]
  journals     Journal[]

  @@index([clientId, periodId])
  @@index([userId])
  @@map("bank_to_tb_sessions")
}

model BankToTBFile {
  id            String   @id @default(uuid())
  sessionId     String   @map("session_id")
  originalName  String   @map("original_name")
  storagePath   String   @map("storage_path")
  containerName String   @default("upload-inbox") @map("container_name")
  fileSize      Int      @map("file_size")
  mimeType      String   @map("mime_type")
  fileHash      String?  @map("file_hash")
  status        String   @default("uploaded") // uploaded | processing | extracted | failed
  errorMessage  String?  @map("error_message")
  pageCount     Int?     @map("page_count")
  createdAt     DateTime @default(now()) @map("created_at")

  session      BankToTBSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([sessionId])
  @@map("bank_to_tb_files")
}

model BankAccount {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  bankName       String?  @map("bank_name")
  sortCode       String?  @map("sort_code")
  accountNumber  String?  @map("account_number")
  accountName    String?  @map("account_name")
  currency       String   @default("GBP")
  openingBalance Float?   @map("opening_balance")
  closingBalance Float?   @map("closing_balance")
  tabOrder       Int      @default(0) @map("tab_order")
  createdAt      DateTime @default(now()) @map("created_at")

  session      BankToTBSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([sessionId])
  @@map("bank_accounts")
}

model BankTransaction {
  id                String   @id @default(uuid())
  sessionId         String   @map("session_id")
  fileId            String?  @map("file_id")
  accountId         String?  @map("account_id")
  date              DateTime
  description       String
  reference         String?
  debit             Float    @default(0)
  credit            Float    @default(0)
  balance           Float?
  bankName          String?  @map("bank_name")
  sortCode          String?  @map("sort_code")
  accountNumber     String?  @map("account_number")
  statementDate     String?  @map("statement_date")
  statementPage     Int?     @map("statement_page")
  accountCode       String?  @map("account_code")
  accountNameMapped String?  @map("account_name_mapped")
  categoryType      String?  @map("category_type")
  inPeriod          Boolean  @default(true) @map("in_period")
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")

  session BankToTBSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  file    BankToTBFile?   @relation(fields: [fileId], references: [id], onDelete: SetNull)
  account BankAccount?    @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([accountId])
  @@map("bank_transactions")
}

model TrialBalanceEntry {
  id                    String   @id @default(uuid())
  sessionId             String   @map("session_id")
  accountCode           String   @map("account_code")
  accountName           String   @map("account_name")
  categoryType          String   @map("category_type")
  openingDebit          Float    @default(0) @map("opening_debit")
  openingCredit         Float    @default(0) @map("opening_credit")
  combinedDebit         Float    @default(0) @map("combined_debit")
  combinedCredit        Float    @default(0) @map("combined_credit")
  columnData            Json?    @map("column_data") // for "Combine as Separate": { accountId: { debit, credit }, ... }
  journalData           Json?    @map("journal_data") // per journal category: { depreciation: { debit, credit }, ... }
  isFromOpeningPosition Boolean  @default(false) @map("is_from_opening_position")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  session BankToTBSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, accountCode])
  @@index([sessionId])
  @@map("trial_balance_entries")
}

model Journal {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  category    String // depreciation | prepayments | accruals | distributions | unbundle_fa | general
  description String?  @db.Text
  status      String   @default("draft") // draft | approved | posted | unposted
  journalRef  String?  @map("journal_ref")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session BankToTBSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lines   JournalLine[]

  @@index([sessionId])
  @@index([sessionId, category])
  @@map("bank_to_tb_journals")
}

model JournalLine {
  id          String  @id @default(uuid())
  journalId   String  @map("journal_id")
  accountCode String  @map("account_code")
  accountName String  @map("account_name")
  description String?
  debit       Float   @default(0)
  credit      Float   @default(0)
  sortOrder   Int     @default(0) @map("sort_order")

  journal Journal @relation(fields: [journalId], references: [id], onDelete: Cascade)

  @@index([journalId])
  @@map("bank_to_tb_journal_lines")
}

