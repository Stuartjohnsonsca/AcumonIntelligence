// ─── Resource Planning ───────────────────────────────────────────────

model ResourceStaffSetting {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  firmId              String   @map("firm_id")
  resourceRole        String   @map("resource_role") // Specialist | Preparer | Reviewer | RI
  concurrentJobLimit  Int      @map("concurrent_job_limit")
  isRI                Boolean  @default(false) @map("is_ri")
  weeklyCapacityHrs   Float    @default(37.5) @map("weekly_capacity_hrs")
  overtimeHrs         Float    @default(0) @map("overtime_hrs")
  preparerJobLimit    Int?     @map("preparer_job_limit")
  reviewerJobLimit    Int?     @map("reviewer_job_limit")
  riJobLimit          Int?     @map("ri_job_limit")
  specialistJobLimit  Int?     @map("specialist_job_limit")
  specialistJobLimits Json?    @map("specialist_job_limits")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  firm Firm @relation(fields: [firmId], references: [id])

  @@index([firmId])
  @@map("resource_staff_settings")
}

model ResourceAllocation {
  id           String   @id @default(uuid())
  firmId       String   @map("firm_id")
  engagementId String   @map("engagement_id")
  userId       String   @map("user_id")
  role         String // Specialist | Preparer | Reviewer | RI
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")
  hoursPerDay  Float    @default(7.5) @map("hours_per_day")
  totalHours   Float?   @map("total_hours")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id])
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  // engagementId is a logical reference — either an AuditEngagement.id or a ResourceJob.id
  // No FK constraint so jobs without a matching AuditEngagement can still be scheduled

  @@index([firmId])
  @@index([userId, startDate, endDate])
  @@index([engagementId])
  @@map("resource_allocations")
}

model ResourceJob {
  id                    String    @id @default(uuid())
  firmId                String    @map("firm_id")
  clientId              String    @map("client_id")
  auditType             String    @map("audit_type")
  periodEnd             DateTime  @map("period_end")
  targetCompletion      DateTime  @map("target_completion")
  budgetHoursSpecialist Float     @default(0) @map("budget_hours_specialist")
  budgetHoursRI         Float     @default(0) @map("budget_hours_ri")
  budgetHoursReviewer   Float     @default(0) @map("budget_hours_reviewer")
  budgetHoursPreparer   Float     @default(0) @map("budget_hours_preparer")
  timesheetHours        Float     @default(0) @map("timesheet_hours")
  schedulingStatus      String    @default("unscheduled") @map("scheduling_status") // unscheduled | pre_scheduled | scheduled | completed
  isScheduleLocked      Boolean   @default(false) @map("is_schedule_locked")
  complianceDeadline    DateTime? @map("compliance_deadline")
  customDeadline        DateTime? @map("custom_deadline")
  jobProfileId          String?   @map("job_profile_id")
  crmJobId              String?   @unique @map("crm_job_id")
  actualHoursSpecialist Float     @default(0) @map("actual_hours_specialist")
  actualHoursRI         Float     @default(0) @map("actual_hours_ri")
  actualHoursReviewer   Float     @default(0) @map("actual_hours_reviewer")
  actualHoursPreparer   Float     @default(0) @map("actual_hours_preparer")
  previousJobId         String?   @map("previous_job_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  firm              Firm                @relation(fields: [firmId], references: [id])
  client            Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobProfile        ResourceJobProfile? @relation(fields: [jobProfileId], references: [id])
  previousJob       ResourceJob?        @relation("JobRollForward", fields: [previousJobId], references: [id])
  rolledForwardJobs ResourceJob[]       @relation("JobRollForward")

  @@index([firmId])
  @@index([schedulingStatus])
  @@map("resource_jobs")
}

model ResourceJobProfile {
  id                          String   @id @default(uuid())
  firmId                      String   @map("firm_id")
  name                        String
  budgetHoursSpecialist       Float    @default(0) @map("budget_hours_specialist")
  budgetHoursRI               Float    @default(0) @map("budget_hours_ri")
  budgetHoursReviewer         Float    @default(0) @map("budget_hours_reviewer")
  budgetHoursPreparer         Float    @default(0) @map("budget_hours_preparer")
  budgetHoursSpecialistDetail Json     @default("{}") @map("budget_hours_specialist_detail")
  isDefault                   Boolean  @default(false) @map("is_default")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  firm           Firm                    @relation(fields: [firmId], references: [id])
  clientSettings ResourceClientSetting[]
  resourceJobs   ResourceJob[]

  @@index([firmId])
  @@map("resource_job_profiles")
}

model ResourceClientSetting {
  id                   String   @id @default(uuid())
  firmId               String   @map("firm_id")
  clientId             String   @unique @map("client_id")
  resourceCategoryId   String?  @map("resource_category_id")
  serviceType          String?  @map("service_type")
  rollForwardTimeframe String?  @map("roll_forward_timeframe")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  firm             Firm                @relation(fields: [firmId], references: [id])
  client           Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resourceCategory ResourceJobProfile? @relation(fields: [resourceCategoryId], references: [id])

  @@index([firmId])
  @@map("resource_client_settings")
}

// ─── Document Templates ──────────────────────────────────────────
model DocumentTemplate {
  id          String   @id @default(cuid())
  firmId      String   @map("firm_id")
  name        String // e.g. "Engagement Letter", "Management Letter"
  description String?
  category    String   @default("general") // general, engagement, reporting, correspondence
  auditType   String   @default("ALL") @map("audit_type") // ALL, SME, PIE, SME_CONTROLS, PIE_CONTROLS
  subject     String? // Email subject line (can contain merge fields)
  content     String   @db.Text // Rich text / HTML with merge field placeholders
  mergeFields Json     @default("[]") @map("merge_fields") // Array of { key, label, source, path }
  recipients  Json     @default("[]") // Array of recipient category keys e.g. ["client","ri","reviewer"]
  isActive    Boolean  @default(true) @map("is_active")
  version     Int      @default(1)
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Document templates (as opposed to email templates) — a document
  // template is a body of Handlebars-enabled HTML that renders into a
  // Word skeleton (header/footer) at generation time. `kind` flips
  // the UI between the two modes; `skeletonId` picks which firm
  // skeleton to stitch the body into.
  kind          String  @default("email") // email | document
  skeletonId    String? @map("skeleton_id")
  // Optional hand-picked sample context for admin preview — lets an
  // admin freeze a preview against a known dataset rather than always
  // running against live engagement data.
  sampleContext Json?   @map("sample_context")

  firm     Firm                  @relation(fields: [firmId], references: [id])
  skeleton FirmDocumentSkeleton? @relation(fields: [skeletonId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([category])
  @@index([kind])
  @@index([skeletonId])
  @@map("document_templates")
}

/// Documents pushed FROM the firm TO the client via the Client Portal
/// (e.g. a rendered Planning Letter). Distinct from EvidenceUpload
/// which carries files in the other direction.
///
/// Rows survive template deletion — `templateId` is SetNull on delete
/// so history of what was sent stays intact even if the template is
/// later re-organised. Blob lives in the `portal-documents` container
/// by convention; the `blobPath` is `${clientId}/${id}_${fileName}`.
model PortalDocument {
  id             String   @id @default(cuid())
  firmId         String   @map("firm_id")
  clientId       String   @map("client_id")
  engagementId   String?  @map("engagement_id")
  templateId     String?  @map("template_id")
  name           String
  description    String?
  category       String   @default("general") // mirrors template category
  fileName       String   @map("file_name")
  contentType    String   @default("application/vnd.openxmlformats-officedocument.wordprocessingml.document") @map("content_type")
  fileSize       Int?     @map("file_size")
  blobPath       String   @map("blob_path")
  containerName  String   @default("portal-documents") @map("container_name")
  uploadedById   String?  @map("uploaded_by_id")
  uploadedByName String?  @map("uploaded_by_name")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([engagementId])
  @@index([firmId])
  @@index([createdAt(sort: Desc)])
  @@map("portal_documents")
}

/// Firm-branded Word document skeleton. Uploaded once per firm (per
/// audit type if desired) and reused by many DocumentTemplates. The
/// uploaded .docx must contain the raw-XML marker `{@body}` in its
/// body flow — the render pipeline injects the rendered template
/// content at that point while preserving the skeleton's header,
/// footer, page setup, fonts, and any fixed preamble/closing text.
model FirmDocumentSkeleton {
  id               String   @id @default(uuid())
  firmId           String   @map("firm_id")
  name             String // e.g. "Johnsons LLP letterhead"
  description      String?
  auditType        String   @default("ALL") @map("audit_type") // ALL | SME | PIE | SME_CONTROLS | PIE_CONTROLS
  storagePath      String   @map("storage_path")
  containerName    String   @default("firm-skeletons") @map("container_name")
  originalFileName String   @map("original_file_name")
  mimeType         String?  @map("mime_type")
  fileSize         Int?     @map("file_size")
  // One default skeleton per firm per audit type — picked automatically
  // when a document template doesn't specify a skeleton explicitly.
  isDefault        Boolean  @default(false) @map("is_default")
  isActive         Boolean  @default(true) @map("is_active")
  uploadedById     String?  @map("uploaded_by_id")
  uploadedByName   String?  @map("uploaded_by_name")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  firm      Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  templates DocumentTemplate[]

  @@index([firmId])
  @@index([firmId, auditType, isDefault])
  @@map("firm_document_skeletons")
}

// One lock record per firm — tracks who holds the resource planning edit session
model ResourcePlanningLock {
  id           String   @id @default(uuid())
  firmId       String   @unique @map("firm_id")
  userId       String   @map("user_id")
  userName     String   @map("user_name")
  lockedAt     DateTime @default(now()) @map("locked_at")
  lastActivity DateTime @default(now()) @map("last_activity")

  @@map("resource_planning_locks")
}

// Optimizer constraint priority settings — one record per firm
model ResourceOptimizerSettings {
  id              String   @id @default(uuid())
  firmId          String   @unique @map("firm_id")
  constraintOrder Json     @default("[]") @map("constraint_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id])

  @@map("resource_optimizer_settings")
}

// ─── Test Execution Engine ─────────────────────────────────────────────────

model TestExecution {
  id              String    @id @default(uuid())
  engagementId    String    @map("engagement_id")
  firmId          String    @map("firm_id")
  fsLine          String    @map("fs_line")
  fsLineId        String?   @map("fs_line_id") // Canonical FK to MethodologyFsLine
  testDescription String    @map("test_description")
  testTypeCode    String?   @map("test_type_code")
  flowSnapshot    Json      @map("flow_snapshot") // Frozen FlowData at execution start
  status          String    @default("running") // running | paused | completed | failed | cancelled
  currentNodeId   String?   @map("current_node_id") // ReactFlow node ID where paused/active
  pauseReason     String?   @map("pause_reason") // portal_response | team_task | evidence | sampling | review
  pauseRefId      String?   @map("pause_ref_id") // ID of external resource being waited on
  context         Json      @default("{}") @map("context") // Accumulated outputs keyed by nodeId
  loopState       Json?     @map("loop_state") // Active forEach/loopUntil state
  errorMessage    String?   @map("error_message") @db.Text
  startedById     String    @map("started_by_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  executionMode    String  @default("flow") @map("execution_mode") // flow | action_pipeline
  currentStepIndex Int?    @map("current_step_index") // For action_pipeline mode
  actionStepId     String? @map("action_step_id") // Current TestActionStep being executed
  pipelineState    Json?   @map("pipeline_state") // Accumulated outputs from completed steps

  // User-supplied answers to the test's pipelineConfigSchema modal, captured
  // before the first action runs. Read by handlers via $ctx.execution.config.
  configJson Json? @map("config_json")

  engagement        AuditEngagement        @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  nodeRuns          TestExecutionNodeRun[]
  outstandingItems  OutstandingItem[]
  sampleItemMarkers SampleItemMarker[]

  @@index([engagementId])
  @@index([status])
  @@index([pauseRefId])
  @@map("test_executions")
}

model TestExecutionNodeRun {
  id           String    @id @default(uuid())
  executionId  String    @map("execution_id")
  nodeId       String    @map("node_id")
  nodeType     String    @map("node_type") // start | action | decision | forEach | loopUntil | wait | end
  assignee     String? // ai | client | team
  label        String?
  status       String    @default("pending") // pending | running | paused | completed | failed | skipped
  input        Json?
  output       Json?
  errorMessage String?   @map("error_message")
  aiModel      String?   @map("ai_model")
  aiTokensUsed Int?      @map("ai_tokens_used")
  duration     Int? // milliseconds
  loopIndex    Int?      @map("loop_index")
  actionStepId String?   @map("action_step_id") // Which pipeline step this node run belongs to
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")

  execution TestExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([executionId, nodeId])
  @@map("test_execution_node_runs")
}

model OutstandingItem {
  id              String    @id @default(uuid())
  engagementId    String    @map("engagement_id")
  executionId     String?   @map("execution_id")
  nodeId          String?   @map("node_id")
  type            String // flow_task | portal_request | evidence_request | review_point
  title           String
  description     String?   @db.Text
  source          String    @default("manual") // flow | manual
  assignedTo      String?   @map("assigned_to")
  status          String    @default("pending") // pending | in_progress | awaiting_client | awaiting_team | complete
  fsLine          String?   @map("fs_line")
  testName        String?   @map("test_name")
  flowNodeType    String?   @map("flow_node_type")
  priority        String    @default("normal") // normal | high | urgent
  portalRequestId String?   @map("portal_request_id")
  responseData    Json?     @map("response_data")
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  execution  TestExecution?  @relation(fields: [executionId], references: [id], onDelete: SetNull)

  @@index([engagementId])
  @@index([engagementId, status])
  @@index([executionId])
  @@map("outstanding_items")
}

// ─── Test Conclusions & Error Handling ───────────────────────────────────────

model AuditTestConclusion {
  id              String  @id @default(uuid())
  engagementId    String  @map("engagement_id")
  executionId     String? @map("execution_id")
  fsLine          String  @map("fs_line")
  fsLineId        String? @map("fs_line_id") // Canonical FK to MethodologyFsLine
  testDescription String  @map("test_description")
  accountCode     String? @map("account_code")

  // Conclusion
  status            String  @default("pending") // pending | concluded | reviewed | signed_off
  conclusion        String? // green | orange | red | failed
  totalErrors       Float   @default(0) @map("total_errors")
  extrapolatedError Float   @default(0) @map("extrapolated_error")
  populationSize    Int     @default(0) @map("population_size")
  sampleSize        Int     @default(0) @map("sample_size")

  // Error items: [{ itemIndex, difference, explanation, isFraud, isIsolated, isAnomaly }]
  errors Json?

  // Auditor analysis
  controlRelianceConcern Boolean @default(false) @map("control_reliance_concern")
  extrapolationExceedsTM Boolean @default(false) @map("extrapolation_exceeds_tm")
  auditorNotes           String? @map("auditor_notes") @db.Text

  // Follow-up actions: ["expand_sample", "alternative_procedures", "request_management", "revise_approach", "error_schedule"]
  followUpActions Json? @map("follow_up_actions")
  followUpData    Json? @map("follow_up_data") // Per-action data (e.g. revise approach text)

  // Review signoffs
  reviewedBy     String?   @map("reviewed_by")
  reviewedByName String?   @map("reviewed_by_name")
  reviewedAt     DateTime? @map("reviewed_at")
  riSignedBy     String?   @map("ri_signed_by")
  riSignedByName String?   @map("ri_signed_by_name")
  riSignedAt     DateTime? @map("ri_signed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@index([engagementId, fsLine])
  @@map("audit_test_conclusions")
}

model AuditAnalyticalReview {
  id           String  @id @default(uuid())
  engagementId String  @map("engagement_id")
  fsLine       String  @map("fs_line")
  accountCode  String  @map("account_code")
  description  String?

  // TB amounts
  recordedAmount  Float @default(0) @map("recorded_amount")
  priorYearAmount Float @default(0) @map("prior_year_amount")

  // Formula selectors (what each variable represents)
  formulaX String? @map("formula_x") // PY value(s) | Sales | CoS | Non-Financial Data | 0 | Opening Balance | 12 | Units Sold
  formulaA String? @map("formula_a")
  formulaB String? @map("formula_b")
  formulaZ String? @map("formula_z") // Change in Sales | Change in CoS | GPM% | Inflation | GDP | FX USD | FX Euro | Interest rate | User Entered

  // Resolved numeric values
  xValue Float? @map("x_value")
  aValue Float? @map("a_value")
  bValue Float? @map("b_value")
  zValue Float? @map("z_value")

  // User-entered explanations (for Non-Financial Data / User Entered selectors)
  xExplanation String? @map("x_explanation") @db.Text
  zExplanation String? @map("z_explanation") @db.Text

  // Calculated results
  expectedAmount       Float?  @map("expected_amount") // X + (A + B) / 2 * Z
  difference           Float? // Recorded - Expected
  toleranceMateriality Float?  @map("tolerance_materiality") // (Recorded / FS Note rollup) × PM
  threshold            Float? // Confidence Factor × Tolerance Materiality
  withinThreshold      Boolean @default(true) @map("within_threshold")

  // Auditor assessment
  justification        String? @db.Text
  differenceAssessment String? @map("difference_assessment") // Isolated and justifiable | Isolated not explainable | Systemic and justifiable | Systemic and not justifiable

  // RMM reconsideration
  rmmErrors          String @default("No") @map("rmm_errors")
  rmmBias            String @default("No") @map("rmm_bias")
  rmmControlFailures String @default("No") @map("rmm_control_failures")
  rmmFraudRisks      String @default("No") @map("rmm_fraud_risks")

  // Sign-offs
  signOffs Json?  @map("sign_offs") // { preparer: {...}, reviewer: {...}, ri: {...} }
  status   String @default("pending") // pending | calculated | reviewed | signed_off

  // Merge support
  mergedWithCode String? @map("merged_with_code") // Account code this is merged into

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, accountCode])
  @@index([engagementId])
  @@index([engagementId, fsLine])
  @@map("audit_analytical_reviews")
}

model AuditPayrollTest {
  id           String @id @default(uuid())
  engagementId String @map("engagement_id")
  fsLine       String @map("fs_line")
  status       String @default("pending") // pending | in_progress | completed | reviewed | signed_off

  // Ingested payroll data (monthly summaries parsed from CSV/Excel)
  payrollData Json? @map("payroll_data") @db.JsonB // { months: [{ period, gross, tax, eeNI, erNI, eePension, erPension, studentLoan, otherDed, netPay, ... }] }

  // Lead schedule (account codes mapped to TB)
  leadSchedule Json? @map("lead_schedule") @db.JsonB // { rows: [{ accountCode, accountName, cyBalance, adjustment, finalCY, pyBalance, variance, pct, wpRef }] }

  // Reconciliation grids
  payrollRecon  Json? @map("payroll_recon") @db.JsonB // { months: [{ period, gross, salSacrifice, tax, eeNI, hscLevy, studentLoan, eePension, netDed, pensionRefund, netPerReport, netPerCalc, diff, erNI, erPension, bankNetPay }], reconToTB: [...] }
  hmrcRecon     Json? @map("hmrc_recon") @db.JsonB // { months: [{ period, paye, studentLoan, erNI, eeNI, other, total, bankDate, bankAmount, bankName, diff, notes }] }
  pensionsRecon Json? @map("pensions_recon") @db.JsonB // { months: [{ period, eePension, erPension, totalPension, bankDate, bankAmount, bankName, diff, notes }] }

  // Joiners & Leavers
  joiners Json? @db.JsonB // [{ name, contractSeen, startMonth, annualSalary, monthlySalary, firstFullMonthPayroll, diff, notes }]
  leavers Json? @db.JsonB // [{ name, p45Seen, lastMonthPaid, lastMonthP45, diff, notes, terminationChecks: {...} }]

  // Holiday pay & accruals
  holidayPay Json? @map("holiday_pay") @db.JsonB // { calculation, liability, accrual, notes }

  // Errors and conclusion
  errors       Json?   @db.JsonB // [{ description, amount, type, section }]
  conclusion   String? // green | orange | red
  auditorNotes String? @map("auditor_notes") @db.Text

  // Sign-offs
  signOffs  Json?    @map("sign_offs") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, fsLine])
  @@index([engagementId])
  @@map("audit_payroll_tests")
}

model AuditErrorSchedule {
  id              String    @id @default(uuid())
  engagementId    String    @map("engagement_id")
  conclusionId    String?   @map("conclusion_id")
  fsLine          String    @map("fs_line")
  accountCode     String?   @map("account_code")
  description     String
  errorAmount     Float     @map("error_amount")
  errorType       String    @map("error_type") // factual | judgemental | projected
  explanation     String?   @db.Text
  isFraud         Boolean   @default(false) @map("is_fraud")
  committedBy     String?   @map("committed_by")
  committedByName String?   @map("committed_by_name")
  committedAt     DateTime? @map("committed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  // Linkage back to the sample item that produced this error. Populated by
  // the Year-End Accruals pipeline (and any future pipeline that uses the
  // Red/Orange/Green marker system). Nullable so legacy/manual errors still
  // fit the same table.
  sampleItemMarkerId String?   @map("sample_item_marker_id")
  // "error" = the Red item flowed through to the error schedule (default
  // when this row exists). "in_tb" = auditor confirmed the item is already
  // reflected in the TB, so no error booked — the row is retained for
  // traceability but excluded from materiality roll-ups.
  resolution         String?   @map("resolution") // error | in_tb
  resolvedBy         String?   @map("resolved_by")
  resolvedByName     String?   @map("resolved_by_name")
  resolvedAt         DateTime? @map("resolved_at")

  engagement       AuditEngagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  sampleItemMarker SampleItemMarker? @relation(fields: [sampleItemMarkerId], references: [id], onDelete: SetNull)

  @@index([engagementId])
  @@index([sampleItemMarkerId])
  @@map("audit_error_schedules")
}

/// Per-sample-item Red / Orange / Green marker, written by pipelines that
/// use the three-colour assessment pattern (e.g. Year-End Accruals).
///
/// One row per verified sample item. The handler's output is the source of
/// truth for `colour` until the user overrides it via the runtime UI, at
/// which point the `overridden*` fields are populated and `colour` is
/// updated in place.
///
/// `calcJson` holds whatever supporting evidence/refs/apportionment figures
/// the handler used to reach its decision so the UI can show "why" on
/// hover and the reviewer can audit the logic.
model SampleItemMarker {
  id               String    @id @default(uuid())
  executionId      String    @map("execution_id")
  stepIndex        Int       @map("step_index") // Which pipeline step emitted this marker
  sampleItemRef    String    @map("sample_item_ref") // Stable key identifying the sample item (e.g. row id)
  colour           String // red | orange | green
  reason           String    @db.Text
  // Narrow classification inside a colour so the UI can render subtitles
  // ("Accrual Supported", "Spread", "Incorrect Accrual", "Support Missing",
  //  "Apportionment OK", "Apportionment Mismatch", etc.). Free-form string
  // to allow future pipelines to reuse the marker infra with their own
  // vocabulary.
  markerType       String?   @map("marker_type")
  calcJson         Json?     @map("calc_json") // Matching refs, apportionment breakdown, etc.
  overriddenBy     String?   @map("overridden_by")
  overriddenByName String?   @map("overridden_by_name")
  overriddenAt     DateTime? @map("overridden_at")
  overrideReason   String?   @map("override_reason") @db.Text
  originalColour   String?   @map("original_colour") // Snapshot of handler-emitted colour when overridden
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  execution          TestExecution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  errorScheduleItems AuditErrorSchedule[]

  @@unique([executionId, stepIndex, sampleItemRef])
  @@index([executionId])
  @@map("sample_item_markers")
}

// ─── Audit Points (Review Points, Management, Representation, RI Matters) ───

model AuditPoint {
  id           String @id @default(uuid())
  engagementId String @map("engagement_id")
  pointType    String @map("point_type") // review_point | management | representation | ri_matter
  chatNumber   Int    @map("chat_number")
  status       String @default("open") // open | closed | committed | cancelled

  // Content
  description String  @db.Text
  heading     String?
  body        String? @db.Text // Rich text body (for management/representation)
  reference   String? @db.Text // URL/path to source location

  // Creator
  createdById   String   @map("created_by_id")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Closure / Commit
  closedById   String?   @map("closed_by_id")
  closedByName String?   @map("closed_by_name")
  closedAt     DateTime? @map("closed_at")

  // Thread responses: [{ id, userId, userName, message, attachments, createdAt }]
  responses Json?

  // Attachments on main point: [{name, url, type, size}]
  attachments Json?

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, pointType])
  @@index([engagementId, pointType, status])
  @@map("audit_points")
}

// ─── Tax Technical Chats ────────────────────────────────────────────────────

model AuditTaxChat {
  id                 String  @id @default(uuid())
  engagementId       String  @map("engagement_id")
  taxCategory        String  @map("tax_category") // vat, corporation_tax, employment_taxes, etc.
  chatNumber         Int     @map("chat_number")
  status             String  @default("open") // open | concluded | referred
  businessBackground String? @map("business_background") @db.Text // Sent with first message

  // Conclusion
  conclusion       String? @db.Text // Tax technical's conclusion
  conclusionStatus String? @map("conclusion_status") // correct | incorrect | needs_adjustment | inconclusive

  // Creator (audit team member)
  createdById   String   @map("created_by_id")
  createdByName String   @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Assigned tax specialist
  assignedToId    String? @map("assigned_to_id") // User ID (internal) or specialist name
  assignedToName  String? @map("assigned_to_name")
  assignedToType  String  @default("internal") @map("assigned_to_type") // internal | external
  delegatedToId   String? @map("delegated_to_id") // If reassigned by the specialist
  delegatedToName String? @map("delegated_to_name")

  // Messages: [{ id, userId, userName, role, message, attachments, createdAt }]
  // role: 'audit_team' | 'tax_specialist'
  messages Json @default("[]")

  // Attachments: [{name, url, type, size}]
  attachments Json?

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId, taxCategory])
  @@index([engagementId, status])
  @@index([assignedToId])
  @@map("audit_tax_chats")
}

// ─── Action-Based Test Pipeline ─────────────────────────────────────────────

model ActionDefinition {
  id          String  @id @default(uuid())
  firmId      String? @map("firm_id") // null = system-global action
  code        String // unique slug: "request_documents", "select_sample"
  name        String // Display: "Request Documents from Client"
  description String? @db.Text
  category    String  @default("general") // evidence | sampling | analysis | verification | reporting
  version     Int     @default(1)

  inputSchema  Json @map("input_schema") // InputFieldDef[]
  outputSchema Json @map("output_schema") // OutputFieldDef[]

  handlerName  String? @map("handler_name") // For system actions: e.g. "requestDocuments"
  internalFlow Json?   @map("internal_flow") // For custom actions: FlowData { nodes, edges }

  icon      String? // lucide icon name
  color     String? // hex color for UI badge
  isSystem  Boolean  @default(false) @map("is_system")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  firm            Firm?            @relation(fields: [firmId], references: [id], onDelete: Cascade)
  testActionSteps TestActionStep[]

  @@unique([firmId, code, version])
  @@index([firmId])
  @@index([category])
  @@map("action_definitions")
}

model TestActionStep {
  id                 String @id @default(uuid())
  testId             String @map("test_id")
  actionDefinitionId String @map("action_definition_id")
  stepOrder          Int    @map("step_order")

  inputBindings   Json  @map("input_bindings") // { fieldCode: value | "$prev.outputField" | "$step.2.outputField" }
  configOverrides Json? @map("config_overrides") // Optional overrides

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  test             MethodologyTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  actionDefinition ActionDefinition @relation(fields: [actionDefinitionId], references: [id])

  @@unique([testId, stepOrder])
  @@index([testId])
  @@map("test_action_steps")
}

// ─── Journal Risk (ISA 240 Management Override) ────────────────────────────

model JournalRiskRun {
  id                 String   @id @default(uuid())
  engagementId       String   @map("engagement_id")
  runId              String   @unique @map("run_id")
  status             String   @default("completed") // completed | superseded
  config             Json // Frozen Config snapshot
  populationEvidence Json     @map("population_evidence") // PopulationEvidence
  selectionSummary   Json     @map("selection_summary") // { layer1, layer2, layer3, notSelected }
  riskModelSnapshot  Json     @map("risk_model_snapshot") // rules, thresholds, weights
  totalJournals      Int      @map("total_journals")
  totalSelected      Int      @map("total_selected")
  runById            String   @map("run_by_id")
  createdAt          DateTime @default(now()) @map("created_at")

  engagement AuditEngagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  runBy      User               @relation("JournalRiskRunBy", fields: [runById], references: [id])
  entries    JournalRiskEntry[]

  @@index([engagementId])
  @@map("journal_risk_runs")
}

model JournalRiskEntry {
  id               String    @id @default(uuid())
  runId            String    @map("run_id")
  journalId        String    @map("journal_id")
  postedAt         String    @map("posted_at")
  period           String
  isManual         Boolean   @map("is_manual")
  preparedByUserId String    @map("prepared_by_user_id")
  approvedByUserId String?   @map("approved_by_user_id")
  amount           Float
  description      String?   @db.Text
  debitAccountId   String    @map("debit_account_id")
  creditAccountId  String    @map("credit_account_id")
  riskScore        Int       @map("risk_score")
  riskBand         String    @map("risk_band") // low | medium | high
  riskTags         Json      @map("risk_tags") // string[]
  drivers          Json // RiskDriver[]
  selected         Boolean   @default(false)
  selectionLayer   String    @map("selection_layer") // layer1_mandatory_high_risk | layer2_targeted_coverage | layer3_unpredictable | not_selected
  mandatory        Boolean   @default(false)
  rationale        String?   @db.Text
  testStatus       String    @default("pending") @map("test_status") // pending | tested | no_exception | exception
  testNotes        String?   @map("test_notes") @db.Text
  testedById       String?   @map("tested_by_id")
  testedAt         DateTime? @map("tested_at")

  run JournalRiskRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([runId, selected])
  @@map("journal_risk_entries")
}

// ─── Meetings & Minutes ────────────────────────────────────────────────────

model AuditMeeting {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  title         String
  meetingDate   DateTime @map("meeting_date")
  meetingType   String   @default("other") @map("meeting_type") // planning | interim | final | other
  attendees     Json? // [{name, role}]
  source        String   @default("manual") // teams | manual
  teamsEventId  String?  @map("teams_event_id")
  transcriptRaw String?  @map("transcript_raw") @db.Text
  minutes       Json? // MeetingMinutes structured object
  minutesStatus String   @default("draft") @map("minutes_status") // draft | generated | reviewed | signed_off
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  createdBy  User            @relation("MeetingCreator", fields: [createdById], references: [id])

  @@index([engagementId])
  @@map("audit_meetings")
}
