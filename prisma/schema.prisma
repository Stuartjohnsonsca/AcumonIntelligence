  firmReviewedBy String?  @map("firm_reviewed_by")
  createdAt      DateTime @default(now()) @map("created_at")

  request  AuditEvidenceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploader ClientPortalUser     @relation(fields: [uploadedBy], references: [id])

  @@index([requestId])
  @@map("evidence_uploads")
}

model PortalUpload {
  id              String   @id @default(uuid())
  portalRequestId String   @map("portal_request_id")
  engagementId    String?  @map("engagement_id")
  clientId        String?  @map("client_id")
  uploadedBy      String   @map("uploaded_by")
  originalName    String   @map("original_name")
  storagePath     String   @map("storage_path")
  containerName   String   @default("upload-inbox") @map("container_name")
  fileSize        Int?     @map("file_size")
  mimeType        String?  @map("mime_type")
  createdAt       DateTime @default(now()) @map("created_at")

  portalRequest PortalRequest @relation(fields: [portalRequestId], references: [id], onDelete: Cascade)

  @@index([portalRequestId])
  @@index([engagementId])
  @@index([clientId])
  @@map("portal_uploads")
}

// ─── Assurance Hub ──────────────────────────────────────────────────────────

model AssuranceChat {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  userId    String   @map("user_id")
  firmId    String   @map("firm_id")
  subTool   String?  @map("sub_tool") // null during triage, set when resolved: Governance | CyberResiliance | TalentRisk | ESGSustainability | Diversity
  status    String   @default("active") // active | resolved | booking_requested
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client     Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id])
  firm       Firm                   @relation(fields: [firmId], references: [id])
  messages   AssuranceChatMessage[]
  engagement AssuranceEngagement?

  @@index([clientId, userId])
  @@index([firmId])
  @@map("assurance_chats")
}

model AssuranceChatMessage {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  role      String // "user" | "assistant" | "system"
  content   String   @db.Text
  metadata  Json? // structured data: recommendedSubTool, shouldBook, etc.
  turnOrder Int      @map("turn_order")
  createdAt DateTime @default(now()) @map("created_at")

  chat AssuranceChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("assurance_chat_messages")
}

model AssuranceEngagement {
  id                String    @id @default(uuid())
  chatId            String    @unique @map("chat_id")
  clientId          String    @map("client_id")
  firmId            String    @map("firm_id")
  userId            String    @map("user_id")
  subTool           String    @map("sub_tool") // Governance | CyberResiliance | TalentRisk | ESGSustainability | Diversity
  engagementType    String    @map("engagement_type") // terms_of_reference | sample_testing | duplicate_transactions
  sector            String?
  projectDetails    Json?     @map("project_details") // captured from chat drill-down
  termsOfReference  String?   @map("terms_of_reference") @db.Text // generated ToR content (JSON)
  torGeneratedAt    DateTime? @map("tor_generated_at")
  reportContent     String?   @map("report_content") @db.Text // final board report content
  reportGeneratedAt DateTime? @map("report_generated_at")
  score             Int? // 0-100 overall score
  status            String    @default("draft") // draft | tor_generated | evidence_collection | review_in_progress | complete
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  chat      AssuranceChat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  client    Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firm      Firm                @relation(fields: [firmId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  documents AssuranceDocument[]
  reports   AssuranceReport[]
  scores    AssuranceScore[]

  @@index([clientId, firmId])
  @@index([userId])
  @@map("assurance_engagements")
}

model AssuranceDocument {
  id               String   @id @default(uuid())
  engagementId     String   @map("engagement_id")
  uploadedById     String   @map("uploaded_by_id")
  originalName     String   @map("original_name")
  storagePath      String   @map("storage_path")
  containerName    String   @default("assurance-evidence") @map("container_name")
  fileSize         Int      @map("file_size")
  mimeType         String   @map("mime_type")
  documentCategory String   @map("document_category") // maps to ToR evidence checklist category
  aiReviewStatus   String   @default("pending") @map("ai_review_status") // pending | reviewing | reviewed
  aiReviewResult   Json?    @map("ai_review_result") // { satisfiesRequirement, findings, gaps, recommendations }
  aiScore          Int?     @map("ai_score") // 0-100 individual document score
  createdAt        DateTime @default(now()) @map("created_at")

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("assurance_documents")
}

model AssuranceReport {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  reportType    String   @map("report_type") // terms_of_reference | board_report
  storagePath   String   @map("storage_path")
  containerName String   @default("assurance-reports") @map("container_name")
  fileHash      String?  @map("file_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("assurance_reports")
}

model AssuranceScore {
  id           String   @id @default(uuid())
  engagementId String   @map("engagement_id")
  clientId     String   @map("client_id")
  firmId       String   @map("firm_id")
  subTool      String   @map("sub_tool")
  sector       String?
  score        Int // 0-100
  scoredAt     DateTime @default(now()) @map("scored_at")
  metadata     Json? // breakdown by section

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([firmId, subTool])
  @@index([sector, subTool])
  @@index([clientId])
  @@map("assurance_scores")
}

model AssuranceLearning {
  id          String   @id @default(uuid())
  firmId      String   @map("firm_id")
  sector      String? // sector this learning applies to, null = all sectors
  subTool     String?  @map("sub_tool") // sub-tool this learning applies to, null = all
  patternType String   @map("pattern_type") // routing_pattern | common_concern | sector_insight | successful_approach
  pattern     String   @db.Text // the learned pattern description
  confidence  Float    @default(0.5) // 0-1, increases with more supporting evidence
  sourceCount Int      @default(1) @map("source_count") // number of chats that contributed to this pattern
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([firmId])
  @@index([sector, subTool])
  @@index([patternType])
  @@map("assurance_learnings")
}

