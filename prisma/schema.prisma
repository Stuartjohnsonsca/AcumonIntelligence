// Per team-member Independence sign-off for an engagement.
// Seeded as status='outstanding' when the audit is started OR when a
// team member is added to an engagement that has already started. Users
// cannot view/interact with the engagement until status='confirmed'. If
// they submit status='declined' the RI and Ethics Partner are emailed.
model AuditMemberIndependence {
  id            String    @id @default(uuid())
  engagementId  String    @map("engagement_id")
  userId        String    @map("user_id")
  status        String    @default("outstanding") // outstanding | confirmed | declined
  isIndependent Boolean?  @map("is_independent") // true = confirmed independent, false = declared NOT independent (declined)
  answers       Json? // [{ questionId, questionText, answer, notes }]
  notes         String?   @db.Text
  confirmedAt   DateTime? @map("confirmed_at")
  notifiedAt    DateTime? @map("notified_at") // when decline email was sent to RI / Ethics Partner
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  engagement AuditEngagement                  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  user       User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  history    AuditMemberIndependenceHistory[]

  @@unique([engagementId, userId])
  @@index([engagementId])
  @@index([userId])
  @@map("audit_member_independence")
}

// Append-only history of every Independence submission (confirm / decline /
// re-confirm on refresh). Each time the team member submits the
// questionnaire — whether positively confirming or declaring themselves
// not independent — a row is inserted here before the current state is
// updated. Never deleted; powers the audit trail.
model AuditMemberIndependenceHistory {
  id                   String    @id @default(uuid())
  memberIndependenceId String    @map("member_independence_id")
  engagementId         String    @map("engagement_id")
  userId               String    @map("user_id")
  status               String // confirmed | declined | outstanding
  isIndependent        Boolean?  @map("is_independent")
  answers              Json?
  notes                String?   @db.Text
  notifiedAt           DateTime? @map("notified_at")
  // What kind of event this row represents:
  //   submission  — team member submitted the questionnaire (confirm or decline)
  //   unbar       — Methodology Admin / Super User cleared a previous decline,
  //                 returning the row to outstanding so the user re-confirms.
  // Default 'submission' so existing rows keep their meaning after the
  // column is added.
  action               String    @default("submission")
  // Who performed the action. Null for old rows (before the column existed)
  // and for self-submissions where the actor is the same as `userId`.
  actorUserId          String?   @map("actor_user_id")
  recordedAt           DateTime  @default(now()) @map("recorded_at")

  memberIndependence AuditMemberIndependence @relation(fields: [memberIndependenceId], references: [id], onDelete: Cascade)

  @@index([memberIndependenceId])
  @@index([engagementId])
  @@index([userId])
  @@map("audit_member_independence_history")
}

