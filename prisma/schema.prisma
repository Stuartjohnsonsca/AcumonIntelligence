  firmId       String   @map("firm_id")
  accountCode  String   @map("account_code")
  accountName  String   @map("account_name")
  categoryType String   @map("category_type") // Fixed Asset, Investment, Current Asset, Current Liability, Long-term Liability, Equity, Revenue, Direct Costs, Overheads, Other Income, Tax Charge, Distribution
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

