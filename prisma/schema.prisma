model TrialBalanceEntry {
  id                    String   @id @default(uuid())
  sessionId             String   @map("session_id")
  accountCode           String   @map("account_code")
  accountName           String   @map("account_name")
  categoryType          String   @map("category_type")
  openingDebit          Float    @default(0) @map("opening_debit")
  openingCredit         Float    @default(0) @map("opening_credit")
  combinedDebit         Float    @default(0) @map("combined_debit")
  combinedCredit        Float    @default(0) @map("combined_credit")
  columnData            Json?    @map("column_data") // for "Combine as Separate": { accountId: { debit, credit }, ... }
  journalData           Json?    @map("journal_data") // per journal category: { depreciation: { debit, credit }, ... }
  isFromOpeningPosition Boolean  @default(false) @map("is_from_opening_position")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  session BankToTBSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, accountCode])
  @@index([sessionId])
  @@map("trial_balance_entries")
}

model Journal {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  category    String // depreciation | prepayments | accruals | distributions | unbundle_fa | general
  description String?  @db.Text
  status      String   @default("draft") // draft | approved | posted | unposted
