// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Firm {
  id         String   @id @default(uuid())
  name       String
  dataRegion String   @default("uk") @map("data_region") // uk | eu | us | ap — determines where data is processed and stored
  taxonomySourceType       String?  @map("taxonomy_source_type") // "url" | "file" — once set, locked for the firm
  taxonomyEndpointUrl      String?  @map("taxonomy_endpoint_url") // URL/API endpoint when sourceType = "url"
  chartOfAccountsBlobPath  String?  @map("chart_of_accounts_blob_path")
  chartOfAccountsContainer String?  @map("chart_of_accounts_container")
  chartOfAccountsFileName  String?  @map("chart_of_accounts_file_name")
  chartOfAccountsUpdatedAt DateTime? @map("chart_of_accounts_updated_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  ethicsPartnerId     String?  @map("ethics_partner_id")

  // PowerApps / Dynamics 365 integration
  powerAppsClientId     String?  @map("power_apps_client_id")
  powerAppsClientSecret String?  @map("power_apps_client_secret")
  powerAppsBaseUrl      String?  @map("power_apps_base_url")
  powerAppsTenantId     String?  @map("power_apps_tenant_id")
  powerAppsClientFilter String?  @map("power_apps_client_filter") // Compiled OData filter for client extraction
  powerAppsClientFilterDesc String? @map("power_apps_client_filter_desc") // Natural language description of the filter
  timesheetLastSyncedAt DateTime? @map("timesheet_last_synced_at") // Last time jca_totalunits was synced from CRM

  users               User[]
  ethicsPartner       User?    @relation("FirmEthicsPartner", fields: [ethicsPartnerId], references: [id])
  clients             Client[]
  samplingConfig      FirmSamplingConfig?
  chartOfAccounts     FirmChartOfAccount[]
  accountCodeMappings AccountCodeMapping[]
  assuranceChats       AssuranceChat[]
  assuranceEngagements AssuranceEngagement[]
  riskChats            RiskChat[]
  iaFeedbackUsers      IAFeedbackUser[]
  // Methodology relations
  auditEngagements         AuditEngagement[]
  clientIntelligence       ClientIntelligence[]
  methodologyConfigs       MethodologyConfig[]
  methodologyTemplates     MethodologyTemplate[]
  methodologyIndustries    MethodologyIndustry[]
  methodologyTestTypes     MethodologyTestType[]
  methodologyTestBanks     MethodologyTestBank[]
  methodologyTests         MethodologyTest[]
  methodologyFsLines       MethodologyFsLine[]
  methodologyToolSettings  MethodologyToolSetting[]
  methodologyRiskTables    MethodologyRiskTable[]
  // Resource planning relations
  resourceStaffSettings    ResourceStaffSetting[]
  resourceAllocations      ResourceAllocation[]
  resourceJobs             ResourceJob[]
  resourceJobProfiles      ResourceJobProfile[]
  resourceClientSettings   ResourceClientSetting[]
  resourceOptimizerSettings ResourceOptimizerSettings?
  documentTemplates        DocumentTemplate[]

  @@map("firms")
}

model User {
  id                String    @id @default(uuid())
  firmId            String    @map("firm_id")
  displayId         String    @unique @map("display_id") // e.g. ST001
  name              String
  email             String    @unique
  passwordHash      String    @map("password_hash")
  twoFactorMethod   String    @default("email") @map("two_factor_method")
  isSuperAdmin       Boolean   @default(false) @map("is_super_admin")
  isFirmAdmin        Boolean   @default(false) @map("is_firm_admin")
  isPortfolioOwner   Boolean   @default(false) @map("is_portfolio_owner")
  isMethodologyAdmin Boolean   @default(false) @map("is_methodology_admin")
  isResourceAdmin    Boolean   @default(false) @map("is_resource_admin")
  isAuditStaff       Boolean   @default(false) @map("is_audit_staff")
  isTestBuilder      Boolean   @default(false) @map("is_test_builder")
  entraObjectId     String?   @unique @map("entra_object_id")
  jobTitle          String?   @map("job_title")
  department        String?
  officeLocation    String?   @map("office_location")
  lastSyncedAt      DateTime? @map("last_synced_at")
  expiryDate        DateTime? @map("expiry_date")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  firm                       Firm                       @relation(fields: [firmId], references: [id])
  twoFactorCodes             TwoFactorCode[]
  clientAssignments          UserClientAssignment[]
  purchasedSubscriptions     Subscription[]
  extractionJobs             ExtractionJob[]
  managedClients             Client[]                   @relation("PortfolioManagerClients")
  docSummaryJobs             DocSummaryJob[]
  activityLogs               ActivityLog[]
  periodProductAssignments   PeriodProductAssignment[]
  samplingEngagements        SamplingEngagement[]
  samplingReviews            SamplingReview[]           @relation("SamplingReviewer")
  samplingEngagementsReview  SamplingEngagement[]       @relation("SamplingEngagementReviewer")
  evidenceRequestsCreated   AuditEvidenceRequest[]     @relation("EvidenceRequestCreator")
  bankToTBSessions           BankToTBSession[]
  bankAuditSessions          BankAuditSession[]
  toolSessions               ToolSession[]
  assuranceChats             AssuranceChat[]
  assuranceEngagements       AssuranceEngagement[]
  riskChats                  RiskChat[]
  riskFeedback               RiskFeedback[]
  iaFeedbackRoles            IAFeedbackUser[]
  assuranceFeedback          AssuranceFeedback[]
  // Methodology relations
  auditTeamMemberships       AuditTeamMember[]
  auditEngagementsCreated    AuditEngagement[]          @relation("EngagementCreator")
  intelligenceReviews        ClientIntelligenceReview[]
  auditDocumentsRequested    AuditDocument[]            @relation("DocumentRequester")
  auditDocumentsUploaded     AuditDocument[]            @relation("DocumentUploader")
  methodologyConfigsCreated  MethodologyConfig[]
  firmEthicsPartnerOf        Firm[]                     @relation("FirmEthicsPartner")
  // Resource planning relations
  resourceStaffSetting       ResourceStaffSetting?
  resourceAllocations        ResourceAllocation[]

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String   // "Statutory Audit" | "Internal Audit"
  urlPrefix   String   @unique @map("url_prefix")
  expiryDays  Int      @map("expiry_days")
  price1      Float    @map("price_1")
  price5      Float    @map("price_5")
  price10     Float    @map("price_10")
  price20     Float    @map("price_20")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  priceChanges  PriceChange[]

  @@map("products")
}

model PriceChange {
  id            String    @id @default(uuid())
  productId     String    @map("product_id")
  effectiveDate DateTime  @map("effective_date")
  price1        Float     @map("price_1")
  price5        Float     @map("price_5")
  price10       Float     @map("price_10")
  price20       Float     @map("price_20")
  committedAt   DateTime  @default(now()) @map("committed_at")
  appliedAt     DateTime? @map("applied_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("price_changes")
}

model Client {
  id                  String   @id @default(uuid())
  firmId              String   @map("firm_id")
  clientName          String   @map("client_name")
  software            String?
  contactFirstName    String?  @map("contact_first_name")
  contactSurname      String?  @map("contact_surname")
  contactEmail        String?  @map("contact_email")
  sector              String?  // Financial Services, Healthcare, Manufacturing, Technology, Public Sector, Retail, Energy, Education, Construction, Legal, Charities & Non-Profit
  portfolioManagerId  String?  @map("portfolio_manager_id")
  crmAccountId        String?  @unique @map("crm_account_id") // Dynamics 365 account GUID
  isActive            Boolean  @default(true) @map("is_active")
  readOnly            Boolean  @default(false) @map("read_only")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  firm                   Firm                    @relation(fields: [firmId], references: [id])
  portfolioManager       User?                   @relation("PortfolioManagerClients", fields: [portfolioManagerId], references: [id], onDelete: SetNull)
  apiKeys                ClientApiKey[]
  subscriptions          Subscription[]
  userAssignments        UserClientAssignment[]
  extractionJobs         ExtractionJob[]
  accountingConnections  AccountingConnection[]
  xeroAuthRequests       XeroAuthRequest[]
  aiUsage                AiUsage[]
  docSummaryJobs         DocSummaryJob[]
  periods                ClientPeriod[]
  samplingEngagements    SamplingEngagement[]
  portalUsers            ClientPortalUser[]
  evidenceRequests       AuditEvidenceRequest[]
  bankToTBSessions       BankToTBSession[]
  chartOfAccounts        ClientChartOfAccount[]
  bankAuditSessions      BankAuditSession[]
  fsAssertionMappings    FSAssertionMapping[]
  assuranceChats         AssuranceChat[]
  assuranceEngagements   AssuranceEngagement[]
  assuranceScores        AssuranceScore[]
  riskChats              RiskChat[]
  // Methodology relations
  auditEngagements       AuditEngagement[]
  clientIntelligence     ClientIntelligence[]
  // Resource planning relations
  resourceJobs           ResourceJob[]
  resourceClientSetting  ResourceClientSetting?
  portalRequests         PortalRequest[]

  @@map("clients")
}

model ClientApiKey {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  apiKey    String   @unique @map("api_key")
  orgName   String   @map("org_name")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_api_keys")
}

model Subscription {
  id               String    @id @default(uuid())
  clientId         String    @map("client_id")
  productId        String    @map("product_id")
  purchasedById    String    @map("purchased_by_id")
  quantity         Int
  startDate        DateTime  @map("start_date")
  expiryDate       DateTime  @map("expiry_date")
  stripePaymentId  String?   @map("stripe_payment_id")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
  purchasedBy User    @relation(fields: [purchasedById], references: [id])

  @@map("subscriptions")
}

model UserClientAssignment {
  userId    String   @map("user_id")
  clientId  String   @map("client_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@map("user_client_assignments")
}

model TwoFactorCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_codes")
}

model PendingProductSelection {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  urlPrefix    String   @map("url_prefix")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_product_selections")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// ─── Access Requests ────────────────────────────────────────────────────────

model AccessRequest {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  clientId      String    @map("client_id")
  token         String    @unique
  status        String    @default("pending") // pending | approved | rejected | expired
  respondedAt   DateTime? @map("responded_at")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("access_requests")
}

// ─── Xero Delegated Auth Requests ───────────────────────────────────────────

model XeroAuthRequest {
  id           String    @id @default(uuid())
  clientId     String    @map("client_id")
  requestedBy  String    @map("requested_by")
  recipientEmail String  @map("recipient_email")
  recipientName  String? @map("recipient_name")
  token        String    @unique
  codeVerifier String?   @map("code_verifier")
  status       String    @default("pending") // pending | authorised | expired
  respondedAt  DateTime? @map("responded_at")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("xero_auth_requests")
}

// ─── Accounting System Connections ───────────────────────────────────────────

model AccountingConnection {
  id              String   @id @default(uuid())
  clientId        String   @map("client_id")
  system          String   // "xero" | "sage" | "quickbooks"
  accessToken     String   @map("access_token")
  refreshToken    String   @map("refresh_token")
  tokenExpiresAt  DateTime @map("token_expires_at")
  tenantId        String?  @map("tenant_id")
  orgName         String?  @map("org_name")
  connectedBy     String   @map("connected_by")
  connectedAt     DateTime @default(now()) @map("connected_at")
  expiresAt       DateTime @map("expires_at")
  accountsCache   Json?    @map("accounts_cache")
  accountsCachedAt DateTime? @map("accounts_cached_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, system])
  @@map("accounting_connections")
}

// Temporary storage for Xero OAuth tokens while user picks an organisation
model PendingXeroAuth {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  accessToken    String   @map("access_token")
  refreshToken   String   @map("refresh_token")
  expiresIn      Int      @map("expires_in")
  connectedBy    String   @map("connected_by")
  isDelegated    Boolean  @default(false) @map("is_delegated")
  delegatedToken String?  @map("delegated_token")
  tenants        Json     // Array of { tenantId, tenantName, createdDateUtc }
  returnUrl      String?  @map("return_url")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("pending_xero_auths")
}

// ─── Data Extraction Tool ────────────────────────────────────────────────────

model ExtractionJob {
  id                   String    @id @default(uuid())
  clientId             String    @map("client_id")
  userId               String    @map("user_id")
  engagementId         String?   @map("engagement_id")    // Links to audit engagement
  testExecutionId      String?   @map("test_execution_id") // Links to test execution that created this job
  fsLine               String?   @map("fs_line")           // FS line being tested
  status               String    @default("pending") // pending | processing | complete | failed | expired
  totalFiles           Int       @default(0) @map("total_files")
  processedCount       Int       @default(0) @map("processed_count")
  failedCount          Int       @default(0) @map("failed_count")
  duplicateCount       Int       @default(0) @map("duplicate_count")
  accountingSystem     String?   @map("accounting_system")
  orgName              String?   @map("org_name")
  extractedAt          DateTime? @map("extracted_at")
  expiresAt            DateTime? @map("expires_at")
  reminderSentAt       DateTime? @map("reminder_sent_at")
  finalReminderSentAt  DateTime? @map("final_reminder_sent_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  client    Client              @relation(fields: [clientId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  files     ExtractionFile[]
  records   ExtractedRecord[]

  @@index([engagementId])
  @@index([testExecutionId])
  @@map("extraction_jobs")
}

model ExtractionFile {
  id            String   @id @default(uuid())
  jobId         String   @map("job_id")
  originalName  String   @map("original_name")
  storagePath   String   @map("storage_path")
  containerName String   @map("container_name")
  fileSize      Int?     @map("file_size")
  mimeType      String?  @map("mime_type")
  wasZipped     Boolean  @default(false) @map("was_zipped")
  zipSourceName String?  @map("zip_source_name")
  status        String   @default("uploaded") // uploaded | processing | extracted | failed | duplicate | expired
  errorMessage  String?  @map("error_message")
  fileHash      String?  @map("file_hash")
  duplicateOfId String?  @map("duplicate_of_id")
  pageCount     Int?     @map("page_count")
  createdAt     DateTime @default(now()) @map("created_at")

  job          ExtractionJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  records      ExtractedRecord[]
  duplicateOf  ExtractionFile?   @relation("FileDuplicates", fields: [duplicateOfId], references: [id])
  duplicates   ExtractionFile[]  @relation("FileDuplicates")

  @@map("extraction_files")
}

model ExtractedRecord {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  fileId          String   @map("file_id")
  referenceId     String   @map("reference_id") // short system-generated ref e.g. DOC-001
  purchaserName   String?  @map("purchaser_name")
  purchaserTaxId  String?  @map("purchaser_tax_id")
  purchaserCountry String? @map("purchaser_country")
  sellerName      String?  @map("seller_name")
  sellerTaxId     String?  @map("seller_tax_id")
  sellerCountry   String?  @map("seller_country")
  documentRef     String?  @map("document_ref")
  documentDate    String?  @map("document_date")
  dueDate         String?  @map("due_date")
  netTotal        Float?   @map("net_total")
  dutyTotal       Float?   @map("duty_total")
  taxTotal        Float?   @map("tax_total")
  grossTotal      Float?   @map("gross_total")
  lineItems       Json?    @map("line_items") // array of {description, quantity, productId, net, tax, duty}
  accountCategory String?  @map("account_category")
  rawExtraction   Json?    @map("raw_extraction")
  fieldLocations  Json?    @map("field_locations")
  createdAt       DateTime @default(now()) @map("created_at")

  job  ExtractionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  file ExtractionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("extracted_records")
}

model AccountCategoryLearning {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  description String   // the description text pattern
  category    String   // the assigned category
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([clientId, description])
  @@map("account_category_learning")
}

// ─── AI Usage Tracking ──────────────────────────────────────────────────────

model AiUsage {
  id               String   @id @default(uuid())
  clientId         String   @map("client_id")
  jobId            String?  @map("job_id")
  fileId           String?  @map("file_id")
  userId           String   @map("user_id")
  action           String   @default("Financial Data Extraction") // which tool/product triggered the AI call
  model            String   // e.g. "gemini-2.5-flash"
  operation        String   // "extraction" | "categorisation"
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalTokens      Int      @map("total_tokens")
  estimatedCostUsd Float    @map("estimated_cost_usd")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, createdAt])
  @@index([userId])
  @@map("ai_usage")
}

// ─── Background Tasks (replaces in-memory task stores) ──────────────────────

model BackgroundTask {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  clientId  String?  @map("client_id")
  type      String   // 'xero-fetch' | 'xero-attachments'
  status    String   @default("running") // running | completed | error
  progress  Json?    // { phase, current, total }
  result    Json?    // task-specific result data
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([createdAt])
  @@map("background_tasks")
}

// ─── Document Summary Tool ──────────────────────────────────────────────────

model DocSummaryJob {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  userId         String    @map("user_id")
  status         String    @default("pending") // pending | processing | complete | failed
  totalFiles     Int       @default(0) @map("total_files")
  processedCount Int       @default(0) @map("processed_count")
  failedCount    Int       @default(0) @map("failed_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime? @map("expires_at")

  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id])
  files    DocSummaryFile[]
  findings DocSummaryFinding[]
  qaMessages DocSummaryQA[]

  @@index([clientId])
  @@index([userId])
  @@map("doc_summary_jobs")
}

model DocSummaryFile {
  id            String    @id @default(uuid())
  jobId         String    @map("job_id")
  originalName  String    @map("original_name")
  storagePath   String    @map("storage_path")
  containerName String    @default("upload-inbox") @map("container_name")
  fileSize      Int       @map("file_size")
  mimeType      String    @map("mime_type")
  status        String    @default("uploaded") // uploaded | processing | analysed | failed
  errorMessage  String?   @map("error_message")
  pageCount            Int?      @map("page_count")
  hidden               Boolean   @default(false)
  documentDescription  String?   @map("document_description") @db.Text
  extractedText        String?   @map("extracted_text") @db.Text
  keyTerms             Json?     @map("key_terms")
  missingInformation   Json?     @map("missing_information")
  createdAt            DateTime  @default(now()) @map("created_at")

  job        DocSummaryJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  findings   DocSummaryFinding[]
  qaMessages DocSummaryQA[]

  @@index([jobId])
  @@map("doc_summary_files")
}

model DocSummaryFinding {
  id                String   @id @default(uuid())
  jobId             String   @map("job_id")
  fileId            String   @map("file_id")
  area              String   // e.g. "Parties", "Obligations", "Risks", or AI-identified area
  finding           String   @db.Text
  clauseReference   String   @map("clause_reference")
  isSignificantRisk   Boolean  @default(false) @map("is_significant_risk")
  aiSignificantRisk   Boolean  @default(false) @map("ai_significant_risk")
  userResponse      String?  @map("user_response") @db.Text
  accountingImpact  String?  @map("accounting_impact") @db.Text
  auditImpact       String?  @map("audit_impact") @db.Text
  addToTesting      Boolean  @default(false) @map("add_to_testing")
  reviewed          Boolean  @default(false)
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")

  job  DocSummaryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  file DocSummaryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([fileId])
  @@map("doc_summary_findings")
}

model DocSummaryQA {
  id        String   @id @default(uuid())
  jobId     String   @map("job_id")
  fileId    String   @map("file_id")
  role      String   // "user" | "assistant"
  content   String   @db.Text
  turnOrder Int      @map("turn_order")
  createdAt DateTime @default(now()) @map("created_at")

  job  DocSummaryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  file DocSummaryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([jobId])
  @@map("doc_summary_qa")
}

// ─── Client Periods & Product Assignments ────────────────────────────────

model ClientPeriod {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client             Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productAssignments PeriodProductAssignment[]
  samplingEngagements SamplingEngagement[]
  evidenceRequests    AuditEvidenceRequest[]
  bankToTBSessions    BankToTBSession[]
  bankAuditSessions   BankAuditSession[]
  fsAssertionMappings FSAssertionMapping[]
  auditEngagements    AuditEngagement[]

  @@unique([clientId, startDate])
  @@map("client_periods")
}

model PeriodProductAssignment {
  id         String   @id @default(uuid())
  periodId   String   @map("period_id")
  productKey String   @map("product_key")
  category   String
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")

  period ClientPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([periodId, productKey, userId])
  @@map("period_product_assignments")
}

// ─── Activity & Error Logging ───────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  firmId    String?  @map("firm_id")
  clientId  String?  @map("client_id")
  action    String   // e.g. 'upload', 'analyse', 'export', 'login', 'xero_connect'
  tool      String?  // e.g. 'doc-summary', 'data-extraction'
  detail    String?  // JSON string with action-specific details
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([firmId])
  @@index([clientId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

model ErrorLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  route     String?  // e.g. '/api/doc-summary/analyse'
  tool      String?  // e.g. 'doc-summary', 'data-extraction'
  message   String
  stack     String?
  context   String?  // JSON string with request context
  severity  String   @default("error") // 'error', 'warning', 'critical'
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([route])
  @@index([severity])
  @@index([createdAt])
  @@index([resolved])
  @@map("error_logs")
}

// ─── Sampling Calculator ─────────────────────────────────────────────────────

model FirmSamplingConfig {
  id                    String   @id @default(uuid())
  firmId                String   @unique @map("firm_id")
  confidenceLevel       Float    @default(95) @map("confidence_level") // e.g. 95 for 95%
  confidenceFactorTable Json?    @map("confidence_factor_table") // [{inherentRisk, specificRisk, overallRMM, riskOfIncorrectAcceptance, confidenceFactorRange}]
  riskMatrix            Json?    @map("risk_matrix") // 3x3 grid: k values by inherent risk x specific risk
  updatedBy             String?  @map("updated_by")
  updatedAt             DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("firm_sampling_configs")
}

model SamplingEngagement {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  periodId    String   @map("period_id")
  userId      String   @map("user_id")
  name        String?  // engagement name / code
  auditArea   String?  @map("audit_area") // e.g. revenue, purchases, payroll
  testingType String?  @map("testing_type") // "test_of_details" | "test_of_controls"
  assertions  Json?    // ["Occurrence", "Completeness", "Accuracy", ...]
  status      String   @default("draft") // draft | configured | running | complete | locked
  reviewerId  String?  @map("reviewer_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period    ClientPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id])
  reviewer  User?        @relation("SamplingEngagementReviewer", fields: [reviewerId], references: [id])
  auditData SamplingAuditData?
  populations SamplingPopulation[]
  runs        SamplingRun[]

  @@index([clientId, periodId])
  @@index([userId])
  @@map("sampling_engagements")
}

model SamplingAuditData {
  id                     String   @id @default(uuid())
  engagementId           String   @unique @map("engagement_id")
  performanceMateriality Float    @map("performance_materiality")
  clearlyTrivial         Float    @map("clearly_trivial")
  tolerableMisstatement  Float    @map("tolerable_misstatement")
  functionalCurrency     String   @default("GBP") @map("functional_currency")
  dataType               String   @map("data_type") // Revenue, Direct Costs, Overheads, etc.
  testType               String   @map("test_type") // one_tail, two_tail, multi_tail
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  engagement SamplingEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@map("sampling_audit_data")
}

model SamplingPopulation {
  id                    String   @id @default(uuid())
  engagementId          String   @map("engagement_id")
  description           String?
  periodStart           DateTime? @map("period_start")
  periodEnd             DateTime? @map("period_end")
  completenessStatement String?  @map("completeness_statement") @db.Text
  recordCount           Int      @default(0) @map("record_count")
  currency              String   @default("GBP")
  unitOfSampling        String?  @map("unit_of_sampling") // transaction, line, journal, invoice, payment
  fileHash              String?  @map("file_hash") // SHA-256 of uploaded file
  originalFileName      String?  @map("original_file_name")
  storagePath           String?  @map("storage_path")
  containerName         String   @default("upload-inbox") @map("container_name")
  columnMapping         Json?    @map("column_mapping") // {transactionId: "col_A", date: "col_B", amount: "col_C", ...}
  dataQualitySummary    Json?    @map("data_quality_summary") // {missingCounts, duplicates, dateRange, outlierStats}
  parsedData            Json?    @map("parsed_data") // stored population rows for engine use
  createdAt             DateTime @default(now()) @map("created_at")

  engagement SamplingEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  runs       SamplingRun[]

  @@index([engagementId])
  @@map("sampling_populations")
}

model SamplingRun {
  id              String   @id @default(uuid())
  engagementId    String   @map("engagement_id")
  populationId    String   @map("population_id")
  parentRunId     String?  @map("parent_run_id") // for extend/rerun linking
  mode            String   // "A" | "B"
  method          String   // random, systematic, mus, judgemental, composite
  stratification  String   @default("simple") // simple | stratified
  parameters      Json     // full config snapshot for reproducibility
  seed            Int?     // PRNG seed
  toolVersion     String   @default("1.0") @map("tool_version")
  status          String   @default("pending") // pending | running | complete | failed
  sampleSize      Int?     @map("sample_size")
  resultSummary   Json?    @map("result_summary") // {meanError, sdError, fpc, ucl, decision, ...}
  coverageSummary Json?    @map("coverage_summary") // {byMonth, byValueBand, byPreparer}
  auditTrailHash  String?  @map("audit_trail_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  engagement  SamplingEngagement  @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  population  SamplingPopulation  @relation(fields: [populationId], references: [id], onDelete: Cascade)
  parentRun   SamplingRun?        @relation("RunExtensions", fields: [parentRunId], references: [id])
  childRuns   SamplingRun[]       @relation("RunExtensions")
  items       SamplingItem[]
  strata      SamplingStratum[]
  judgementChat SamplingJudgementChat[]
  reviews     SamplingReview[]
  artifacts   SamplingExportArtifact[]
  evidenceRequests AuditEvidenceRequest[]

  @@index([engagementId])
  @@index([populationId])
  @@map("sampling_runs")
}

model SamplingItem {
  id              String   @id @default(uuid())
  runId           String   @map("run_id")
  transactionId   String   @map("transaction_id")
  bookValue       Float    @map("book_value")
  auditedValue    Float?   @map("audited_value")
  selectedReason  String?  @map("selected_reason")
  stratumId       String?  @map("stratum_id")
  testResult      String?  @map("test_result") // no_exception | exception | not_testable
  wpReference     String?  @map("wp_reference")
  exceptionAmount Float?   @map("exception_amount")
  exceptionType   String?  @map("exception_type")
  createdAt       DateTime @default(now()) @map("created_at")

  run     SamplingRun      @relation(fields: [runId], references: [id], onDelete: Cascade)
  stratum SamplingStratum? @relation(fields: [stratumId], references: [id])

  @@index([runId])
  @@map("sampling_items")
}

model SamplingStratum {
  id           String @id @default(uuid())
  runId        String @map("run_id")
  name         String
  definition   Json?  // {scoreRange, ruleFlags, ...}
  itemCount    Int    @default(0) @map("item_count")
  totalValue   Float  @default(0) @map("total_value")
  summaryStats Json?  @map("summary_stats")

  run   SamplingRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  items SamplingItem[]

  @@index([runId])
  @@map("sampling_strata")
}

model SamplingJudgementChat {
  id        String   @id @default(uuid())
  runId     String   @map("run_id")
  role      String   // "user" | "assistant"
  content   String   @db.Text
  turnOrder Int      @map("turn_order")
  createdAt DateTime @default(now()) @map("created_at")

  run SamplingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("sampling_judgement_chat")
}

model SamplingReview {
  id         String   @id @default(uuid())
  runId      String   @map("run_id")
  reviewerId String   @map("reviewer_id")
  notes      String?  @db.Text
  decision   String   // approved | rejected | needs_revision
  createdAt  DateTime @default(now()) @map("created_at")

  run      SamplingRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  reviewer User        @relation("SamplingReviewer", fields: [reviewerId], references: [id])

  @@index([runId])
  @@map("sampling_reviews")
}

model SamplingExportArtifact {
  id           String   @id @default(uuid())
  runId        String   @map("run_id")
  artifactType String   @map("artifact_type") // sampling_plan_pdf | sample_schedule_xlsx | coverage_appendix | run_log_json
  fileHash     String?  @map("file_hash")
  storagePath  String?  @map("storage_path")
  containerName String  @default("sampling-artifacts") @map("container_name")
  createdAt    DateTime @default(now()) @map("created_at")

  run SamplingRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("sampling_export_artifacts")
}

// ─── Client Audit Portal ──────────────────────────────────────────────────────

model ClientPortalUser {
  id                 String    @id @default(uuid())
  clientId           String    @map("client_id")
  email              String
  name               String
  passwordHash       String    @map("password_hash")
  isActive           Boolean   @default(true) @map("is_active")
  isClientAdmin      Boolean   @default(false) @map("is_client_admin")
  role               String?   @map("role") // e.g. Finance Director, Accounts Manager, etc
  allocatedPeriodIds Json?     @map("allocated_period_ids") // Array of period IDs this user is allocated to
  allocatedServices  Json?     @map("allocated_services") // Array of service keys: audit, accounting, consulting, tax, technology
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client             Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  twoFactorCodes     ClientPortalTwoFactor[]
  evidenceUploads    EvidenceUpload[]

  @@unique([clientId, email])
  @@map("client_portal_users")
}

model ClientPortalTwoFactor {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("client_portal_two_factor")
}

// ─── Portal Requests (Outstanding / Responded) ──────────────────────────────

model PortalRequest {
  id            String    @id @default(uuid())
  clientId      String    @map("client_id")
  engagementId  String?   @map("engagement_id")
  section       String    // questions | calculations | evidence | connections
  question      String    @db.Text
  response      String?   @db.Text
  status        String    @default("outstanding") // outstanding | responded | verified | committed | chat_replied
  requestedById String    @map("requested_by_id") // Firm User who created the request
  requestedByName String  @map("requested_by_name")
  respondedById String?   @map("responded_by_id") // ClientPortalUser who responded
  respondedByName String? @map("responded_by_name")
  requestedAt   DateTime  @default(now()) @map("requested_at")
  respondedAt   DateTime? @map("responded_at")
  verifiedAt    DateTime? @map("verified_at")
  chatHistory   Json?     @map("chat_history") // Array of { from, name, message, timestamp }
  evidenceTag   String?   @map("evidence_tag") // Structured tag for evidence type (e.g. bank_statements, invoices)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, status])
  @@index([engagementId])
  @@index([engagementId, evidenceTag])
  @@map("portal_requests")
}

// ─── Audit Evidence Requests ──────────────────────────────────────────────────

model AuditEvidenceRequest {
  id              String   @id @default(uuid())
  runId           String   @map("run_id")
  clientId        String   @map("client_id")
  periodId        String   @map("period_id")
  createdBy       String   @map("created_by")
  transactionId   String   @map("transaction_id")
  description     String   @db.Text
  amount          Float?
  date            String?
  reference       String?
  contact         String?
  // Evidence type checkboxes
  invoiceRequired       Boolean @default(false) @map("invoice_required")
  paymentRequired       Boolean @default(false) @map("payment_required")
  supplierConfirmation  Boolean @default(false) @map("supplier_confirmation")
  debtorConfirmation    Boolean @default(false) @map("debtor_confirmation")
  contractRequired      Boolean @default(false) @map("contract_required")
  intercompanyRequired  Boolean @default(false) @map("intercompany_required")
  directorMatters       Boolean @default(false) @map("director_matters")
  // Status tracking
  status          String   @default("pending") // pending | partial | complete | cancelled
  assignedTo      Json?    @map("assigned_to") // Array of client team member emails
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  run       SamplingRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period    ClientPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  creator   User         @relation("EvidenceRequestCreator", fields: [createdBy], references: [id])
  uploads   EvidenceUpload[]

  @@index([runId])
  @@index([clientId, periodId])
  @@map("audit_evidence_requests")
}

model EvidenceUpload {
  id              String   @id @default(uuid())
  requestId       String   @map("request_id")
  uploadedBy      String   @map("uploaded_by") // ClientPortalUser ID
  originalName    String   @map("original_name")
  storagePath     String   @map("storage_path")
  containerName   String   @default("audit-evidence") @map("container_name")
  fileSize        Int?     @map("file_size")
  mimeType        String?  @map("mime_type")
  evidenceType    String   @map("evidence_type") // invoice | payment | supplier_confirmation | debtor_confirmation | contract | intercompany | director_matters
  // Verification
  aiVerified      Boolean? @map("ai_verified") // null=pending, true=matches, false=mismatch
  aiVerifyNotes   String?  @map("ai_verify_notes") @db.Text
  firmAccepted    Boolean? @map("firm_accepted") // null=pending, true=accepted, false=rejected
  firmReviewedBy  String?  @map("firm_reviewed_by")
  createdAt       DateTime @default(now()) @map("created_at")

  request         AuditEvidenceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploader        ClientPortalUser     @relation(fields: [uploadedBy], references: [id])

  @@index([requestId])
  @@map("evidence_uploads")
}

model PortalUpload {
  id              String   @id @default(uuid())
  portalRequestId String   @map("portal_request_id")
  engagementId    String?  @map("engagement_id")
  clientId        String?  @map("client_id")
  uploadedBy      String   @map("uploaded_by")
  originalName    String   @map("original_name")
  storagePath     String   @map("storage_path")
  containerName   String   @default("upload-inbox") @map("container_name")
  fileSize        Int?     @map("file_size")
  mimeType        String?  @map("mime_type")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([portalRequestId])
  @@index([engagementId])
  @@index([clientId])
  @@map("portal_uploads")
}

// ─── Assurance Hub ──────────────────────────────────────────────────────────

model AssuranceChat {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  userId    String   @map("user_id")
  firmId    String   @map("firm_id")
  subTool   String?  @map("sub_tool") // null during triage, set when resolved: Governance | CyberResiliance | TalentRisk | ESGSustainability | Diversity
  status    String   @default("active") // active | resolved | booking_requested
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  client     Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User                   @relation(fields: [userId], references: [id])
  firm       Firm                   @relation(fields: [firmId], references: [id])
  messages   AssuranceChatMessage[]
  engagement AssuranceEngagement?

  @@index([clientId, userId])
  @@index([firmId])
  @@map("assurance_chats")
}

model AssuranceChatMessage {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  metadata  Json?    // structured data: recommendedSubTool, shouldBook, etc.
  turnOrder Int      @map("turn_order")
  createdAt DateTime @default(now()) @map("created_at")

  chat AssuranceChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("assurance_chat_messages")
}

model AssuranceEngagement {
  id              String    @id @default(uuid())
  chatId          String    @unique @map("chat_id")
  clientId        String    @map("client_id")
  firmId          String    @map("firm_id")
  userId          String    @map("user_id")
  subTool         String    @map("sub_tool") // Governance | CyberResiliance | TalentRisk | ESGSustainability | Diversity
  engagementType  String    @map("engagement_type") // terms_of_reference | sample_testing | duplicate_transactions
  sector          String?
  projectDetails  Json?     @map("project_details") // captured from chat drill-down
  termsOfReference String?  @map("terms_of_reference") @db.Text // generated ToR content (JSON)
  torGeneratedAt  DateTime? @map("tor_generated_at")
  reportContent   String?   @map("report_content") @db.Text // final board report content
  reportGeneratedAt DateTime? @map("report_generated_at")
  score           Int?      // 0-100 overall score
  status          String    @default("draft") // draft | tor_generated | evidence_collection | review_in_progress | complete
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  chat      AssuranceChat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  client    Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  firm      Firm                @relation(fields: [firmId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  documents AssuranceDocument[]
  reports   AssuranceReport[]
  scores    AssuranceScore[]

  @@index([clientId, firmId])
  @@index([userId])
  @@map("assurance_engagements")
}

model AssuranceDocument {
  id               String   @id @default(uuid())
  engagementId     String   @map("engagement_id")
  uploadedById     String   @map("uploaded_by_id")
  originalName     String   @map("original_name")
  storagePath      String   @map("storage_path")
  containerName    String   @default("assurance-evidence") @map("container_name")
  fileSize         Int      @map("file_size")
  mimeType         String   @map("mime_type")
  documentCategory String   @map("document_category") // maps to ToR evidence checklist category
  aiReviewStatus   String   @default("pending") @map("ai_review_status") // pending | reviewing | reviewed
  aiReviewResult   Json?    @map("ai_review_result") // { satisfiesRequirement, findings, gaps, recommendations }
  aiScore          Int?     @map("ai_score") // 0-100 individual document score
  createdAt        DateTime @default(now()) @map("created_at")

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("assurance_documents")
}

model AssuranceReport {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  reportType    String   @map("report_type") // terms_of_reference | board_report
  storagePath   String   @map("storage_path")
  containerName String   @default("assurance-reports") @map("container_name")
  fileHash      String?  @map("file_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("assurance_reports")
}

model AssuranceScore {
  id           String   @id @default(uuid())
  engagementId String   @map("engagement_id")
  clientId     String   @map("client_id")
  firmId       String   @map("firm_id")
  subTool      String   @map("sub_tool")
  sector       String?
  score        Int      // 0-100
  scoredAt     DateTime @default(now()) @map("scored_at")
  metadata     Json?    // breakdown by section

  engagement AssuranceEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([firmId, subTool])
  @@index([sector, subTool])
  @@index([clientId])
  @@map("assurance_scores")
}

model AssuranceLearning {
  id          String   @id @default(uuid())
  firmId      String   @map("firm_id")
  sector      String?  // sector this learning applies to, null = all sectors
  subTool     String?  @map("sub_tool") // sub-tool this learning applies to, null = all
  patternType String   @map("pattern_type") // routing_pattern | common_concern | sector_insight | successful_approach
  pattern     String   @db.Text // the learned pattern description
  confidence  Float    @default(0.5) // 0-1, increases with more supporting evidence
  sourceCount Int      @default(1) @map("source_count") // number of chats that contributed to this pattern
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([firmId])
  @@index([sector, subTool])
  @@index([patternType])
  @@map("assurance_learnings")
}

// ─── Risk Chat (Lyra) ──────────────────────────────────────────────────

model RiskChat {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  userId         String   @map("user_id")
  firmId         String   @map("firm_id")
  status         String   @default("active") // active | action_plan_generated | accepted | booking_requested
  commitmentType String?  @map("commitment_type") // user_activity | system_work | auditor_work | software_dev
  actionPlan     Json?    @map("action_plan")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User             @relation(fields: [userId], references: [id])
  firm     Firm             @relation(fields: [firmId], references: [id])
  messages RiskChatMessage[]

  @@index([clientId, userId])
  @@index([firmId])
  @@map("risk_chats")
}

model RiskChatMessage {
  id        String   @id @default(uuid())
