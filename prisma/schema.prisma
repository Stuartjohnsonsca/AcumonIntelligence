// ─── G3Q Performance Dashboard ─────────────────────────────────────────
// All data backing the AQT lead's Performance Dashboard. Each model is
// firm-scoped. The dashboard *derives* headline KPIs from these tables —
// nothing is hard-coded. Empty tables produce "no data yet" panels.

// One row per audit-quality monitoring activity (cold/hot/spot/thematic
// file review, EQR process review, technical consultation, FS pre-issuance
// review, ethical compliance review).
model PerfMonitoringActivity {
  id                        String    @id @default(uuid())
  firmId                    String    @map("firm_id")
  activityType              String    @map("activity_type") // cold | hot | spot | thematic | eqr | consultation | preissuance | ethical
  engagementName            String?   @map("engagement_name") // free text — links to engagementId optional
  engagementId              String?   @map("engagement_id")
  responsibleIndividualName String?   @map("ri_name")
  managerName               String?   @map("manager_name")
  reviewerName              String?   @map("reviewer_name")
  plannedDate               DateTime? @map("planned_date")
  startedDate               DateTime? @map("started_date")
  completedDate             DateTime? @map("completed_date")
  status                    String    @default("planned") // planned | in_progress | complete | overdue | cancelled
  outcomeRating             String?   @map("outcome_rating") // good | limited_improvements | improvements_required | significant_improvements
  qualityScore              Int?      @map("quality_score") // 0-100
  findingsCount             Int       @default(0) @map("findings_count")
  notes                     String?   @db.Text
  createdById               String?   @map("created_by_id")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  firm     Firm          @relation(fields: [firmId], references: [id], onDelete: Cascade)
  findings PerfFinding[]

  @@index([firmId, activityType])
  @@index([firmId, status])
  @@map("perf_monitoring_activities")
}

// A finding raised from a monitoring activity. Root-cause category is
// chosen post-RCA. RCA closure rate = closed / total over period.
model PerfFinding {
  id                String    @id @default(uuid())
  firmId            String    @map("firm_id")
  activityId        String?   @map("activity_id")
  title             String
  description       String?   @db.Text
  rootCauseCategory String?   @map("root_cause_category") // process | methodology | supervision | data_ipe | resourcing | other
  severity          String    @default("medium") // low | medium | high | critical
  raisedDate        DateTime  @default(now()) @map("raised_date")
  rcaCompletedDate  DateTime? @map("rca_completed_date")
  closedDate        DateTime? @map("closed_date")
  status            String    @default("open") // open | rca_in_progress | rca_complete | closed
  notes             String?   @db.Text
  createdById       String?   @map("created_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  firm         Firm                    @relation(fields: [firmId], references: [id], onDelete: Cascade)
  activity     PerfMonitoringActivity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  remediations PerfRemediation[]

  @@index([firmId, status])
  @@index([firmId, rootCauseCategory])
  @@map("perf_findings")
}

// Remediation actions linked to a finding. Effectiveness is set when the
// firm re-tests after implementation (Jul/Jan reporting cycle).
model PerfRemediation {
  id           String    @id @default(uuid())
  firmId       String    @map("firm_id")
  findingId    String    @map("finding_id")
  description  String    @db.Text
  ownerName    String?   @map("owner_name")
  dueDate      DateTime? @map("due_date")
  status       String    @default("not_started") // not_started | in_progress | implemented | retested | overdue
  retestedDate DateTime? @map("retested_date")
  effective    Boolean? // true | false | null (not yet retested)
  notes        String?   @db.Text
  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  firm    Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  finding PerfFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)

  @@index([firmId, status])
  @@map("perf_remediations")
}

// Critical Success Factor tracker — one row per CSF defined in the AQMP.
model PerfCsf {
  id            String    @id @default(uuid())
  firmId        String    @map("firm_id")
  pillar        String // goodwill | governance | growth | quality
  subComponent  String    @map("sub_component") // free text — e.g. "Branding", "People", "Risks"
  name          String
  targetMetric  String?   @map("target_metric")
  currentMetric String?   @map("current_metric")
  rag           String    @default("grey") // green | amber | red | grey
  ownerName     String?   @map("owner_name")
  reviewedDate  DateTime? @map("reviewed_date")
  notes         String?   @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId, pillar])
  @@map("perf_csfs")
}

// People metric snapshot — captured each period (e.g. Jul/Jan).
model PerfPeopleSnapshot {
  id                       String   @id @default(uuid())
  firmId                   String   @map("firm_id")
  periodLabel              String   @map("period_label")
  periodEnd                DateTime @map("period_end")
  trainingEffectivenessPct Float?   @map("training_effectiveness_pct")
  staffUtilisationPct      Float?   @map("staff_utilisation_pct")
  cultureSurveyScore       Float?   @map("culture_survey_score") // 0-5
  attritionPct             Float?   @map("attrition_pct")
  notes                    String?  @db.Text
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, periodLabel])
  @@index([firmId, periodEnd])
  @@map("perf_people_snapshots")
}

// Annual G3Q activity schedule (the Gantt). One row per planned activity
// per month per year — the firm seeds the year's plan, then updates status.
model PerfActivitySchedule {
  id            String    @id @default(uuid())
  firmId        String    @map("firm_id")
  year          Int
  monthIndex    Int       @map("month_index") // 0-11
  activityName  String    @map("activity_name")
  status        String    @default("planned") // planned | on_track | at_risk | overdue | done
  ownerName     String?   @map("owner_name")
  dueDate       DateTime? @map("due_date")
  completedDate DateTime? @map("completed_date")
  notes         String?   @db.Text
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, year, monthIndex, activityName])
  @@index([firmId, year])
  @@map("perf_activity_schedule")
}

// ISQM(UK)1 evidence per quality objective.
model PerfIsqmEvidence {
  id            String    @id @default(uuid())
  firmId        String    @map("firm_id")
  objective     String // governance_leadership | ethics | acceptance_continuance | engagement_performance | resources | information_communication | monitoring_remediation | risk_assessment
  evidenceCount Int       @default(0) @map("evidence_count")
  targetCount   Int       @default(0) @map("target_count")
  rag           String    @default("grey") // green | amber | red | grey — manual override of the auto-derived RAG
  ragManual     Boolean   @default(false) @map("rag_manual")
  notes         String?   @db.Text
  reviewedDate  DateTime? @map("reviewed_date")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, objective])
  @@map("perf_isqm_evidence")
}

// Optional manual pillar score override + strapline for the dashboard
// pillar cards. If `manualScore` is null, the dashboard auto-derives the
// score from CSF RAG + monitoring activity completion.
model PerfPillarScore {
  id           String    @id @default(uuid())
  firmId       String    @map("firm_id")
  pillar       String // goodwill | governance | growth | quality
  manualScore  Int?      @map("manual_score") // 0-100
  strapline    String?
  reviewedDate DateTime? @map("reviewed_date")
  notes        String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, pillar])
  @@map("perf_pillar_scores")
}

// ─── AI Reliance Defensibility ────────────────────────────────────────
// Three tables backing the AQT lead's regulatory-defensible position on
// AI use across the audit practice (FRC supervisory expectations under
// ISQM(UK)1 / ISA 220 (Revised) on the use of automated tools and
// techniques): (1) every AI tool the firm uses is registered with scope,
// risk, owner, and validation status; (2) every significant use is
// logged with the human-review decision so override rate can be
// evidenced; (3) validation tests are recorded so the firm can show
// each tool was tested before approval and re-tested on a defined
// cadence.

model PerfAiTool {
  id                String    @id @default(uuid())
  firmId            String    @map("firm_id")
  name              String // e.g. "Journal entry risk scoring (Together AI Llama 3.3)"
  vendor            String?
  modelVersion      String?   @map("model_version")
  auditArea         String?   @map("audit_area") // revenue | je_testing | risk_assessment | controls | analytics | documentation | research | other
  scopeOfUse        String?   @map("scope_of_use") @db.Text
  riskRating        String    @default("medium") @map("risk_rating") // low | medium | high | critical
  ownerName         String?   @map("owner_name")
  validationStatus  String    @default("pending") @map("validation_status") // pending | validated | under_review | withdrawn
  lastValidatedDate DateTime? @map("last_validated_date")
  nextValidationDue DateTime? @map("next_validation_due")
  approvedForUse    Boolean   @default(false) @map("approved_for_use")
  approvedByName    String?   @map("approved_by_name")
  approvedDate      DateTime? @map("approved_date")
  humanInLoop       Boolean   @default(true) @map("human_in_loop")
  notes             String?   @db.Text
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  firm        Firm               @relation(fields: [firmId], references: [id], onDelete: Cascade)
  usage       PerfAiUsage[]
  validations PerfAiValidation[]

  @@index([firmId, isActive])
  @@index([firmId, riskRating])
  @@map("perf_ai_tools")
}

model PerfAiUsage {
  id             String   @id @default(uuid())
  firmId         String   @map("firm_id")
  toolId         String   @map("tool_id")
  engagementName String?  @map("engagement_name")
  engagementId   String?  @map("engagement_id")
  usedDate       DateTime @default(now()) @map("used_date")
  reviewerName   String?  @map("reviewer_name")
  outputDecision String   @map("output_decision") // accepted | overridden | partial | rejected
  materiality    String   @default("medium") // low | medium | high | critical
  notes          String?  @db.Text
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  firm Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  tool PerfAiTool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([firmId, toolId])
  @@index([firmId, usedDate])
  @@map("perf_ai_usage")
}

model PerfAiValidation {
  id          String   @id @default(uuid())
  firmId      String   @map("firm_id")
  toolId      String   @map("tool_id")
  testDate    DateTime @default(now()) @map("test_date")
  testType    String   @map("test_type") // accuracy | bias | regression | edge_case | drift | golden_set | other
  result      String // pass | fail | partial
  performedBy String?  @map("performed_by")
  sampleSize  Int?     @map("sample_size")
  accuracyPct Float?   @map("accuracy_pct")
  evidenceUrl String?  @map("evidence_url")
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  firm Firm       @relation(fields: [firmId], references: [id], onDelete: Cascade)
  tool PerfAiTool @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([firmId, toolId])
  @@index([firmId, testDate])
  @@map("perf_ai_validations")
}
