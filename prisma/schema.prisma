model MethodologyFsLine {
  id              String  @id @default(uuid())
  firmId          String  @map("firm_id")
  name            String // e.g. "Revenue", "Trade Debtors", "Going Concern" — treated as the FS Note Level name
  lineType        String  @map("line_type") // fs_line_item | note_item (legacy classifier, kept for back-compat)
  fsCategory      String  @map("fs_category") // pnl | balance_sheet | cashflow | notes (legacy, kept for back-compat)
  // New firm-configurable FS hierarchy. Every FS Note Level (row in
  // this table) may be tagged with a parent FS Level and FS Statement,
  // both of which are free-form strings chosen from the firm's own
  // option lists (stored in MethodologyRiskTable with tableType
  // 'fs_level_options' / 'fs_statement_options'). Kept as denormalised
  // strings rather than FKs so renaming an option doesn't orphan rows.
  fsLevelName     String? @map("fs_level_name")
  fsStatementName String? @map("fs_statement_name")
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")
  isMandatory     Boolean @default(false) @map("is_mandatory")
