// ─── Client Audit Portal ──────────────────────────────────────────────────────

model ClientPortalUser {
  id                 String    @id @default(uuid())
  clientId           String    @map("client_id")
  email              String
  name               String
  passwordHash       String    @map("password_hash")
  isActive           Boolean   @default(true) @map("is_active")
  isClientAdmin      Boolean   @default(false) @map("is_client_admin")
  role               String?   @map("role") // e.g. Finance Director, Accounts Manager, etc
  allocatedPeriodIds Json?     @map("allocated_period_ids") // Array of period IDs this user is allocated to
  allocatedServices  Json?     @map("allocated_services") // Array of service keys: audit, accounting, consulting, tax, technology
  lastLoginAt        DateTime? @map("last_login_at")
  // Server-side session token. Set on successful login/2FA verify and
  // required by every portal API endpoint so we can't answer with the
  // wrong tenant's data — previous behaviour used a client-generated
  // token that the server never checked, which let one portal user
  // see another's details.
  sessionToken       String?   @unique @map("session_token")
  sessionExpiresAt   DateTime? @map("session_expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  client                     Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  twoFactorCodes             ClientPortalTwoFactor[]
  evidenceUploads            EvidenceUpload[]
  portalPrincipalEngagements AuditEngagement[]         @relation("PortalPrincipalForEngagement")
  portalStaffMemberships     ClientPortalStaffMember[] @relation("StaffMemberPortalUser")

  @@unique([clientId, email])
  @@index([sessionToken])
  @@map("client_portal_users")
}

model ClientPortalTwoFactor {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user ClientPortalUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("client_portal_two_factor")
}

// ─── Portal Requests (Outstanding / Responded) ──────────────────────────────

model PortalRequest {
  id              String    @id @default(uuid())
  clientId        String    @map("client_id")
  engagementId    String?   @map("engagement_id")
  section         String // questions | calculations | evidence | connections
  question        String    @db.Text
  response        String?   @db.Text
  status          String    @default("outstanding") // outstanding | responded | verified | committed | chat_replied
  requestedById   String    @map("requested_by_id") // Firm User who created the request
  requestedByName String    @map("requested_by_name")
  respondedById   String?   @map("responded_by_id") // ClientPortalUser who responded
  respondedByName String?   @map("responded_by_name")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  respondedAt     DateTime? @map("responded_at")
  verifiedAt      DateTime? @map("verified_at")
  chatHistory     Json?     @map("chat_history") // Array of { from, name, message, timestamp }
  evidenceTag     String?   @map("evidence_tag") // Structured tag for evidence type (e.g. bank_statements, invoices)

  // Portal Principal routing: FS Line / TB code this request relates
  // to, if any. Used by the work-allocation engine to pick the
  // assignee. Null routingFsLineId AND null routingTbAccountCode →
  // request is not associated with an FS area, so it routes to the
  // Portal Principal who can manually assign it.
  routingFsLineId      String? @map("routing_fs_line_id")
  routingTbAccountCode String? @map("routing_tb_account_code")

  // Live assignment. Updated as escalations progress. When null, the
  // request is effectively sitting with the Portal Principal.
  assignedPortalUserId String?   @map("assigned_portal_user_id")
  assignedAt           DateTime? @map("assigned_at")

  // Escalation state. 0 = assigned to column-1 staff; 1 = also notified
  // column-2; 2 = also notified column-3; 3 = escalated to Portal
  // Principal after all three columns elapsed without response.
  escalationLevel Int   @default(0) @map("escalation_level")
  escalationLog   Json? @map("escalation_log") // [{ at, fromUserId, toUserId, reason }]

  client  Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploads PortalUpload[]

  @@index([clientId])
  @@index([clientId, status])
  @@index([engagementId])
  @@index([engagementId, evidenceTag])
  @@index([assignedPortalUserId])
  @@index([engagementId, status, escalationLevel])
  @@map("portal_requests")
}

// ─── Portal Principal: Staff Members & Work Allocation ────────────────────────
// One row per client-side staff member that the Portal Principal has
// approved for an engagement. `accessConfirmed` is the strict gate —
// until it's true, the linked ClientPortalUser cannot log in for this
// engagement (enforced at /api/portal/auth/login). Staff members carry
// forward from prior period / sibling group company when the Portal
// Principal kicks off setup.
model ClientPortalStaffMember {
  id                        String   @id @default(uuid())
  clientId                  String   @map("client_id")
  engagementId              String   @map("engagement_id")
  portalUserId              String?  @map("portal_user_id") // linked once the Portal Principal has a matching ClientPortalUser
  name                      String
  email                     String
  role                      String? // free text — e.g. "Payroll Manager", "CFO"
  accessConfirmed           Boolean  @default(false) @map("access_confirmed")
  isActive                  Boolean  @default(true) @map("is_active")
  inheritedFromEngagementId String?  @map("inherited_from_engagement_id") // prior period / sibling group carry-forward
  addedByPortalUserId       String?  @map("added_by_portal_user_id")
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement   @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  portalUser ClientPortalUser? @relation("StaffMemberPortalUser", fields: [portalUserId], references: [id], onDelete: SetNull)

  @@unique([engagementId, email])
  @@index([engagementId])
  @@index([portalUserId])
  @@map("client_portal_staff_members")
}

// Per-engagement work allocation. One row per (FS Line, optional TB
// code) — three staff slots (escalation columns) pointing at
// ClientPortalUser rows. When tbAccountCode is null the row covers
// the whole FS Line; when set it overrides for that specific TB code
// (which is only visible when the FS Line row is expanded). fsLineId
// is nullable to allow a catch-all row for requests with no FS Line
// context, though in practice the Portal Principal picker handles
// those by default.
model ClientPortalWorkAllocation {
  id            String   @id @default(uuid())
  clientId      String   @map("client_id")
  engagementId  String   @map("engagement_id")
  fsLineId      String?  @map("fs_line_id")
  tbAccountCode String?  @map("tb_account_code")
  staff1UserId  String?  @map("staff1_user_id")
  staff2UserId  String?  @map("staff2_user_id")
  staff3UserId  String?  @map("staff3_user_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, fsLineId, tbAccountCode])
  @@index([engagementId])
  @@map("client_portal_work_allocations")
}

// ─── Portal AI Search Log ────────────────────────────────────────────────────
// Every free-text search the portal user runs on their Principal / Audit
// dashboards gets logged here. Two uses:
//   1. Tells the Methodology Admin which queries portal users actually
//      type, so they can promote the popular / useful ones to "featured"
//      — featured queries appear as one-click chips on the Principal
//      dashboard (saves users re-typing common searches).
//   2. Trains future work on query patterns — what portal users look for
//      is a signal the methodology layer might want to expose natively.
model PortalSearchLog {
  id                  String    @id @default(uuid())
  firmId              String    @map("firm_id")
  engagementId        String?   @map("engagement_id") // may be null for multi-engagement queries
  clientId            String?   @map("client_id")
  portalUserId        String?   @map("portal_user_id")
  firmUserId          String?   @map("firm_user_id") // if a firm user ever runs portal search
  query               String    @db.Text
  queryNormalised     String?   @map("query_normalised") @db.Text // lower-cased, trimmed, for dedup/aggregation
  resultCount         Int       @default(0) @map("result_count")
  // AI interpretation — the structured filter object the LLM produced
  // from the natural-language query. Cached here so re-running a
  // saved search doesn't need to call the model again. Shape matches
  // the dashboard's filter state: { status, fsLineIds, tbAccountCodes,
  // assigneeIds, textMatch, reasoning }.
  interpretedFilters  Json?     @map("interpreted_filters")
  // Per-user saved search — when a user clicks "Save" on a search
  // they ran, this log row gets the three fields below set. The
  // Principal dashboard lists all rows where savedByPortalUserId =
  // caller as quick-filter chips. Deleting a saved search just
  // clears these three fields so we keep the log trail intact.
  savedByPortalUserId String?   @map("saved_by_portal_user_id")
  savedLabel          String?   @map("saved_label")
  savedAt             DateTime? @map("saved_at")
  // Featured = Methodology Admin promoted this query so it appears
  // as a quick-filter chip on EVERY Principal dashboard for the firm.
  // Featured rows also carry a display label + who promoted it + when.
  featured            Boolean   @default(false)
  featuredLabel       String?   @map("featured_label")
  featuredById        String?   @map("featured_by_id")
  featuredAt          DateTime? @map("featured_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([firmId, featured])
  @@index([firmId, queryNormalised])
  @@index([engagementId])
  @@index([savedByPortalUserId])
  @@map("portal_search_logs")
}

// ─── Audit Evidence Requests ──────────────────────────────────────────────────

