  isNewClient             Boolean?  @map("is_new_client") // null = auto-detect, true = force new client, false = force continuance
  tbViewMode              String    @default("fs_line") @map("tb_view_mode") // fs_line | tb_account
  tbXeroSummary           Json?     @map("tb_xero_summary") // Raw accounting system TB totals for verification
  planCreated             Boolean   @default(false) @map("plan_created")
  farEnabled              Boolean   @default(false) @map("far_enabled")
  farAssetType            String?   @map("far_asset_type") // "cost" | "valuation"
  farScope                String?   @map("far_scope") // "tangible" | "intangible" | "both"
