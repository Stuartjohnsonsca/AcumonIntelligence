/// Firm-scoped registry of cloud audit-software connectors a firm can
/// pull a prior audit file from at the start of a new engagement.
/// "MyWorkPapers" is seeded as an entry with a stub adapter; new
/// vendors are added via the Import Options pop-up's "Other Cloud
/// Audit Software" path which writes a row here. Credentials are NOT
/// stored on this row — only the connection recipe (base URL, auth
/// scheme, endpoint paths). End-user credentials are entered per
/// connection attempt and never persisted.
model CloudAuditConnector {
  id           String   @id @default(uuid())
  firmId       String   @map("firm_id")
  vendorKey    String   @map("vendor_key") // slug: 'my_workpapers' | user-defined slug
  label        String   // display name in dropdown
  // Connector recipe — how to talk to the vendor's API.
  //   {
  //     baseUrl: string,
  //     authScheme: 'bearer' | 'basic' | 'api_key' | 'oauth2',
  //     authConfig: { headerName?: string, oauth2: {...} },   // shape varies by scheme
  //     endpoints: {
  //       listClients?: { method, path, jsonPath? },
  //       listPeriods?: { method, path, jsonPath? },
  //       fetchEngagement?: { method, path, jsonPath? },
  //       downloadArchive?: { method, path },
  //     },
  //     fieldHints?: { ...optional vendor-specific tweaks }
  //   }
  config       Json
  isBuiltIn    Boolean  @default(false) @map("is_built_in") // true for the seeded MyWorkPapers entry
  isActive     Boolean  @default(true) @map("is_active")
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  firm      Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdBy User @relation("CloudConnectorCreator", fields: [createdById], references: [id])

  @@unique([firmId, vendorKey])
  @@index([firmId])
  @@map("cloud_audit_connectors")
}

// ─── OAuth 2.1 server (for the Acumon MCP custom integration) ────────
// Implements the subset of OAuth that MCP custom-integration clients
// (claude.ai, Cowork CLI, etc.) need: dynamic client registration,
// authorization-code with PKCE, refresh tokens, and access tokens
// scoped to a User + Firm. Tokens are stored hashed (sha256, no salt
// — they're already 256-bit random) so a DB leak doesn't yield active
// bearers; lookup is by `tokenHash`.

/// OAuth client registered against this Acumon installation. Created
/// either via Dynamic Client Registration (RFC 7591) or by an admin via
/// the methodology-admin UI for a fixed integration. Most rows will be
/// claude.ai sideload registrations, one per user-install.
model OAuthClient {
  id                       String   @id @default(uuid())
  clientId                 String   @unique @map("client_id")
  /// SHA-256 hash of clientSecret, when one was issued. NULL for public
  /// clients (PKCE-only). MCP clients are typically public.
  clientSecretHash         String?  @map("client_secret_hash")
  clientName               String   @map("client_name")
  /// JSON array of permitted redirect URIs.
  redirectUris             Json     @map("redirect_uris")
  tokenEndpointAuthMethod  String   @default("none") @map("token_endpoint_auth_method") // none | client_secret_basic | client_secret_post
  grantTypes               Json     @default("[\"authorization_code\", \"refresh_token\"]") @map("grant_types")
  /// Optional firm scoping — when set, only users in this firm may
  /// authenticate against this client. NULL means any firm.
  firmId                   String?  @map("firm_id")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  authCodes    OAuthAuthCode[]
  accessTokens OAuthAccessToken[]

  @@index([firmId])
  @@map("oauth_clients")
}

/// Short-lived (60 s) authorization code issued at /oauth/authorize once
/// the user has consented. Bound to the requesting client + redirectUri
/// + PKCE code challenge; redeemed once at /oauth/token.
model OAuthAuthCode {
  code                  String   @id // 32 bytes random, base64url
  clientId              String   @map("client_id")
  userId                String   @map("user_id")
  firmId                String   @map("firm_id")
  redirectUri           String   @map("redirect_uri")
  codeChallenge         String   @map("code_challenge")
  codeChallengeMethod   String   @map("code_challenge_method") // S256 only
  scope                 String?  // space-separated; only "mcp" supported for now
  /// Optional resource indicator (RFC 8707) — the audience the issued
  /// access token will be valid for. We always set this to the canonical
  /// MCP endpoint URL.
  resource              String?
  expiresAt             DateTime @map("expires_at")
  used                  Boolean  @default(false)
  createdAt             DateTime @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId])
  @@index([expiresAt])
  @@map("oauth_auth_codes")
}

/// Issued access token. Lookup by `tokenHash` (sha256 of the bearer);
/// the raw token never persists. Refresh tokens follow the same pattern.
/// `revokedAt` is set on token rotation (a refresh issues a new pair and
/// retires the old one) and on explicit user-driven revocation.
model OAuthAccessToken {
  id                    String    @id @default(uuid())
  tokenHash             String    @unique @map("token_hash")
  refreshTokenHash      String?   @unique @map("refresh_token_hash")
  clientId              String    @map("client_id")
  userId                String    @map("user_id")
  firmId                String    @map("firm_id")
  scope                 String?
  resource              String?
  expiresAt             DateTime  @map("expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  revokedAt             DateTime? @map("revoked_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  client OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([expiresAt])
  @@map("oauth_access_tokens")
}

/// One-time session that an external AI assistant (e.g. Claude Cowork
/// with the Acumon MCP server registered) uses to drive a prior-period
/// import on behalf of the user. Session token IS the bearer credential
/// — no other auth required for the duration. Single-use; once a file is
/// submitted (or the TTL elapses) the session is closed.
///
/// Lifecycle: pending → submitted | expired | cancelled.
/// On submitted: `submittedDocumentId` points at the AuditDocument row
/// the assistant uploaded; the modal polling /handoff/status sees the
/// flip and advances the user to the Review screen.
model ImportHandoffSession {
  id                    String   @id // base32 random — 32+ chars; THIS is the bearer token
  engagementId          String   @map("engagement_id")
  firmId                String   @map("firm_id")
  createdById           String   @map("created_by_id")
  vendorLabel           String   @map("vendor_label") // shown to the assistant via get_session_context
  status                String   @default("pending") // pending | submitted | expired | cancelled
  // Granular progress within the pending lifecycle. The modal renders
  // this as a progress bar so the user can see what the assistant is
  // doing in real time. Stages, in order:
  //   'created'        — /handoff/start fired (default; row freshly written)
  //   'discovered'     — assistant called list_pending_sessions
  //   'context_loaded' — assistant called get_session_context for this session
  //   'uploading'      — submit_archive received bytes, blob upload in flight
  //   'extracting'     — blob uploaded, AI extraction in flight
  //   'submitted'      — extraction complete, ImportExtractionProposal exists
  // When status flips to expired/cancelled, progressStage is left as it was.
  progressStage         String   @default("created") @map("progress_stage")
  progressMessage       String?  @map("progress_message")
  progressAt            DateTime? @map("progress_at")
  expiresAt             DateTime @map("expires_at")
  submittedDocumentId   String?  @map("submitted_document_id")
  submittedExtractionId String?  @map("submitted_extraction_id")
  submittedAt           DateTime? @map("submitted_at")
  createdAt             DateTime @default(now()) @map("created_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@index([status])
  @@map("import_handoff_sessions")
}

/// Per-engagement scratchpad of an AI-extracted "proposed mapping" of
/// prior-audit-file data → current-engagement tab fields. Created when
/// the user uploads or pulls a prior file, edited row-by-row in the
/// Review pop-up, then collapsed into the engagement's tab JSON blobs
/// when the user clicks Approve. Kept after approval purely as audit
/// trail (status='applied'); a fresh extraction creates a new row
/// rather than mutating in place.
model ImportExtractionProposal {
  id            String   @id @default(uuid())
  engagementId  String   @map("engagement_id")
  // Where the data came from — mirrors AuditEngagement.importOptions.source.
  sourceType    String   @map("source_type") // upload | cloud | cloud_other
  sourceLabel   String?  @map("source_label") // e.g. file name or 'MyWorkPapers — XYZ Ltd 2025'
  sourceArchiveDocumentId String? @map("source_archive_document_id")
  // The proposed rows. Shape:
  //   [{
  //     id: string,                   // stable row id for delete/edit
  //     tabKey: string,               // 'ethics' | 'materiality' | ...
  //     destination: { kind: 'json_blob' | 'row_table', section?, fieldKey?, rowId?, column? },
  //     fieldLabel: string,           // human-readable label of destination
  //     sourceLocation: string,       // hover-over: e.g. "Ethics > Independence > Q3"
  //     proposedValue: any,           // editable
  //     deleted: boolean,             // soft-delete in the Review pop-up
  //     applied?: boolean
  //   }]
  proposals     Json     @default("[]")
  // Captured AI-generation metadata for audit trail.
  aiModel       String?  @map("ai_model")
  rawAiResponse String?  @map("raw_ai_response") @db.Text
  status        String   @default("pending") // pending | applied | cancelled
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  appliedAt     DateTime? @map("applied_at")
  appliedById   String?  @map("applied_by_id")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@index([status])
  @@map("import_extraction_proposals")
}

/// Methodology-admin generated PDF snapshot of an engagement file.
/// Produced on demand by the "Generate PDF Report" action; stored in
/// Azure blob; surfaced via a viewer page that strips download
/// controls for everyone except methodology admins. One row per
/// generated report, so an admin can keep a history.
model AuditPdfReport {
  id              String   @id @default(uuid())
  engagementId    String   @map("engagement_id")
  generatedAt     DateTime @default(now()) @map("generated_at")
  generatedById   String   @map("generated_by_id")
  generatedByName String   @map("generated_by_name")
  fileName        String   @map("file_name")
  blobPath        String   @map("blob_path")
  containerName   String   @default("audit-pdf-reports") @map("container_name")
  fileSize        Int      @map("file_size")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_pdf_reports")
}

model AuditTeamMember {
  id           String   @id @default(uuid())
  engagementId String   @map("engagement_id")
  userId       String   @map("user_id")
  role         String // Junior | Manager | RI | EQR
  joinedAt     DateTime @default(now()) @map("joined_at")
  /// Position within the engagement's team list. Drives the order
  /// shown on the Opening tab and the order document templates see
  /// when iterating `team` via `{{#each team}}`. Lower number = higher
  /// in the list. New members default to 0; the team-save endpoint
  /// re-numbers from the array index on every PUT.
  sortOrder    Int      @default(0) @map("sort_order")
  /// Free-text override for the role label shown on client-facing
  /// documents. The role-select on the Opening tab still drives
  /// system behaviour (Reviewer sign-offs, EQR limits, RI familiarity
  /// gate); this is purely the string {{roleLabel}} resolves to inside
  /// document templates. Empty/null → fall back to the system map
  /// (Junior→Preparer, Manager→Reviewer, RI→Partner, EQR→EQR) so
