model AuditPARRow {
  id                       String  @id @default(uuid())
  engagementId             String  @map("engagement_id")
  particulars              String
  currentYear              Float?  @map("current_year")
  priorYear                Float?  @map("prior_year")
  absVariance              Float?  @map("abs_variance")
  absVariancePercent       Float?  @map("abs_variance_percent")
  significantChange        Boolean @default(false) @map("significant_change")
  sentToManagement         Boolean @default(false) @map("sent_to_management")
  sendMgtData              Json?   @map("send_mgt_data") // { checked, checkedBy, checkedAt, sentAt, respondedAt }
  managementResponseStatus String? @map("management_response_status") // pending | responded
  reasons                  String? @db.Text
  auditorView              String? @map("auditor_view") @db.Text
  addedToRmm               Boolean @default(false) @map("added_to_rmm")
  addedToRmmBy             String? @map("added_to_rmm_by")
  sortOrder                Int     @default(0) @map("sort_order")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_par_rows")
}

model AuditRMMRow {
  id                  String  @id @default(uuid())
  engagementId        String  @map("engagement_id")
  lineItem            String  @map("line_item")
  lineType            String  @map("line_type") // fs_line | tb_account
  riskIdentified      String? @map("risk_identified") @db.Text
  amount              Float?
  assertions          Json? // Array of assertion strings
  relevance           String? // Y | N
  complexityText      String? @map("complexity_text") @db.Text
  subjectivityText    String? @map("subjectivity_text") @db.Text
  changeText          String? @map("change_text") @db.Text
  uncertaintyText     String? @map("uncertainty_text") @db.Text
  susceptibilityText  String? @map("susceptibility_text") @db.Text
  inherentRiskLevel   String? @map("inherent_risk_level") // Remote | Low | Medium | High | Very High
  aiSummary           String? @map("ai_summary") @db.Text
  isAiEdited          Boolean @default(false) @map("is_ai_edited")
  likelihood          String? // Remote | Unlikely | Neutral | Likely | Very Likely
  magnitude           String? // Remote | Low | Medium | High | Very High
  finalRiskAssessment String? @map("final_risk_assessment")
  controlRisk         String? @map("control_risk") // Not Tested | Not Effective | Partially Effective | Effective
  overallRisk         String? @map("overall_risk")
  rowCategory         String? @map("row_category") // significant_risk | area_of_focus | null — drives planning letter risk sections
  isHidden            Boolean @default(false) @map("is_hidden")
  isMandatory         Boolean @default(false) @map("is_mandatory")
  notes               String? @db.Text
  sortOrder           Int     @default(0) @map("sort_order")
  // FS hierarchy — auto-populated when imported from TB/PAR
  fsStatement         String? @map("fs_statement") // e.g. "Profit & Loss"
  fsLevel             String? @map("fs_level") // e.g. "Revenue"
  fsNote              String? @map("fs_note") // e.g. "Trade Debtors"

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_rmm_rows")
}

model AuditDocument {
  id              String    @id @default(uuid())
  engagementId    String    @map("engagement_id")
  documentName    String    @map("document_name")
  requestedFrom   String?   @map("requested_from")
  requestedDate   DateTime? @map("requested_date")
  requestedById   String?   @map("requested_by_id")
  uploadedDate    DateTime? @map("uploaded_date")
  uploadedById    String?   @map("uploaded_by_id")
  storagePath     String?   @map("storage_path")
  containerName   String    @default("audit-documents") @map("container_name")
  fileSize        Int?      @map("file_size")
  mimeType        String?   @map("mime_type")
  visibleToClient Boolean   @default(false) @map("visible_to_client")
  receivedByName  String?   @map("received_by_name")
  receivedAt      DateTime? @map("received_at")
  verifiedOn      DateTime? @map("verified_on")
  verifiedByName  String?   @map("verified_by_name") // "AI" for auto-verification
  utilisedOn      DateTime? @map("utilised_on")
  utilisedByName  String?   @map("utilised_by_name")
  utilisedTab     String?   @map("utilised_tab") // which tab the document is used in
  mappedItems     Json?     @map("mapped_items") // JSON array of item keys this doc maps to
  source          String?   @map("source") // e.g. Client, Bank, Solicitor, Third Party, Team
  usageLocation   String?   @map("usage_location") // which tab/section: Ethics, Materiality, etc.
  documentType    String?   @map("document_type") // e.g. Bank Statement, Confirmation, Invoice
  createdAt       DateTime  @default(now()) @map("created_at")

  engagement  AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  requestedBy User?           @relation("DocumentRequester", fields: [requestedById], references: [id])
  uploadedBy  User?           @relation("DocumentUploader", fields: [uploadedById], references: [id])

  @@index([engagementId])
  @@map("audit_documents")
}

model AuditTBRow {
  id                  String  @id @default(uuid())
  engagementId        String  @map("engagement_id")
  accountCode         String  @map("account_code") // Working code — may change to merged code
  originalAccountCode String? @map("original_account_code") // Real code from TB import, never changes
  description         String
  category            String? // User-defined classification, toggleable
  currentYear         Float?  @map("current_year")
  priorYear           Float?  @map("prior_year")
  fsNoteLevel         String? @map("fs_note_level")
  fsLevel             String? @map("fs_level")
  fsLineId            String? @map("fs_line_id") // Canonical FK to MethodologyFsLine
  fsStatement         String? @map("fs_statement")
  groupName           String? @map("group_name") // Only display for GROUP audit type
  aiConfidence        Int?    @map("ai_confidence") // 0-100 confidence of AI classification
  sourceMetadata      Json?   @map("source_metadata") // Additional data from accounting system (e.g. { xeroType, xeroClass })
  farSchedule         Json?   @map("far_schedule") // Fixed Asset Register movement data per category
  sortOrder           Int     @default(0) @map("sort_order")

  // Firm/client-level classification: is this TB row an accruals/creditors account?
  // Used by the Year-End Accruals pipeline to reconcile the client-supplied
  // accruals listing total back to the TB. Defaults false; flipped either
  // manually by the methodology admin or inferred from fsLine mapping.
  isAccrualAccount Boolean @default(false) @map("is_accrual_account")

  engagement      AuditEngagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  canonicalFsLine MethodologyFsLine? @relation(fields: [fsLineId], references: [id], onDelete: SetNull)

  @@index([engagementId])
  @@index([fsLineId])
  @@map("audit_tb_rows")
}

