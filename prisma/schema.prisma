  clientId     String   @map("client_id")
  accountCode  String   @map("account_code")
  accountName  String   @map("account_name")
  categoryType String   @map("category_type")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, accountCode])
  @@index([clientId])
  @@map("client_chart_of_accounts")
}

// ─── Bank Audit Tool ─────────────────────────────────────────────────────────

model BankAuditSession {
  id                    String   @id @default(uuid())
  userId                String   @map("user_id")
  clientId              String   @map("client_id")
  periodId              String   @map("period_id")
  performanceMateriality Float?  @map("performance_materiality")
  clearlyTrivial        Float?   @map("clearly_trivial")
  tolerableError        Float?   @map("tolerable_error")
  functionalCurrency    String   @default("GBP") @map("functional_currency")
  dataSource            String?  @map("data_source")
  bankData              Json?    @map("bank_data")
  auditTestResults      Json?    @map("audit_test_results")
  status                String   @default("draft")
  reviewedBy            String?  @map("reviewed_by")
  reviewedAt            DateTime? @map("reviewed_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period  ClientPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  tests   BankAuditTest[]
  files   BankAuditFile[]

  @@unique([clientId, periodId, userId])
  @@index([userId])
  @@index([clientId])
  @@map("bank_audit_sessions")
}

model BankAuditTest {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  testKey     String   @map("test_key")
  testLabel   String   @map("test_label")
  isChecked   Boolean  @default(false) @map("is_checked")
  status      String   @default("pending")
  progress    Float    @default(0)
  resultData  Json?    @map("result_data")
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  session BankAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("bank_audit_tests")
}

model BankAuditFile {
  id          String   @id @default(uuid())
  sessionId   String   @map("session_id")
  fileName    String   @map("file_name")
  blobPath    String   @map("blob_path")
  container   String
  fileType    String   @map("file_type")
  status      String   @default("uploading")
  progress    Float    @default(0)
  extractedData Json?  @map("extracted_data")
  errorMsg    String?  @map("error_msg")
  createdAt   DateTime @default(now()) @map("created_at")

  session BankAuditSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("bank_audit_files")
}

// ─── FS Assertions Mapping ───────────────────────────────────────────────────

model FSAssertionMapping {
  id           String  @id @default(uuid())
  clientId     String  @map("client_id")
  periodId     String  @map("period_id")
  mappingType  String  @map("mapping_type")
  rowKey       String  @map("row_key")
  rowLabel     String  @map("row_label")
  completeness Boolean @default(false)
  occurrence   Boolean @default(false)
  cutOff       Boolean @default(false) @map("cut_off")
  classification Boolean @default(false)
  presentation Boolean @default(false)
  existence    Boolean @default(false)
  valuation    Boolean @default(false)
  rights       Boolean @default(false)
  source       String  @default("manual")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  client Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period ClientPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([clientId, periodId, mappingType, rowKey])
  @@index([clientId, periodId])
  @@map("fs_assertion_mappings")
}

// ─── Audit Methodology ──────────────────────────────────────────────────────

model AuditEngagement {
  id                    String    @id @default(uuid())
  clientId              String    @map("client_id")
  periodId              String    @map("period_id")
  firmId                String    @map("firm_id")
  auditType             String    @map("audit_type") // SME | PIE | SME_CONTROLS | PIE_CONTROLS | GROUP
  status                String    @default("pre_start") // pre_start | active | review | complete | archived
  methodologyVersionId  String?   @map("methodology_version_id")
  infoRequestType       String    @default("standard") @map("info_request_type") // preliminary | standard
  hardCloseDate         DateTime? @map("hard_close_date")
  isGroupAudit          Boolean   @default(false) @map("is_group_audit")
  tbViewMode            String    @default("fs_line") @map("tb_view_mode") // fs_line | tb_account
  tbXeroSummary         Json?     @map("tb_xero_summary") // Raw accounting system TB totals for verification
  planCreated           Boolean   @default(false) @map("plan_created")
  createdById           String    @map("created_by_id")
  startedAt             DateTime? @map("started_at")
  completedAt           DateTime? @map("completed_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  client              Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period              ClientPeriod          @relation(fields: [periodId], references: [id], onDelete: Cascade)
  firm                Firm                  @relation(fields: [firmId], references: [id])
  createdBy           User                  @relation("EngagementCreator", fields: [createdById], references: [id])
  methodologyVersion  MethodologyConfig?    @relation(fields: [methodologyVersionId], references: [id])
  teamMembers         AuditTeamMember[]
  specialists         AuditSpecialist[]
  contacts            AuditClientContact[]
  agreedDates         AuditAgreedDate[]
  informationRequests AuditInformationRequest[]
  permanentFile       AuditPermanentFile[]
  ethics              AuditEthics?
  continuance         AuditContinuance?
  newClientTakeOn     AuditNewClientTakeOn?
  materiality         AuditMateriality?
  parRows             AuditPARRow[]
  rmmRows             AuditRMMRow[]
  documents           AuditDocument[]
  tbRows              AuditTBRow[]
  testExecutions       TestExecution[]
  outstandingItems     OutstandingItem[]
  testConclusions      AuditTestConclusion[]
  errorScheduleItems   AuditErrorSchedule[]
  auditPoints          AuditPoint[]
  @@unique([clientId, periodId, auditType])
  @@index([firmId])
  @@index([createdById])
  @@map("audit_engagements")
}

model AuditTeamMember {
  id           String   @id @default(uuid())
  engagementId String   @map("engagement_id")
  userId       String   @map("user_id")
  role         String   // Junior | Manager | RI
  joinedAt     DateTime @default(now()) @map("joined_at")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([engagementId, userId])
  @@index([engagementId])
  @@map("audit_team_members")
}

model AuditSpecialist {
  id             String  @id @default(uuid())
  engagementId   String  @map("engagement_id")
  name           String
  email          String?
  specialistType String  @map("specialist_type") // Specialist | Expert | EthicsPartner | TechnicalAdvisor
  firmName       String? @map("firm_name")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_specialists")
}

model AuditClientContact {
  id           String  @id @default(uuid())
  engagementId String  @map("engagement_id")
  name         String
  email        String?
  phone        String?
  isMainContact Boolean @default(false) @map("is_main_contact")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_client_contacts")
}

model AuditAgreedDate {
  id            String    @id @default(uuid())
  engagementId  String    @map("engagement_id")
  description   String
  targetDate    DateTime? @map("target_date")
  revisedTarget DateTime? @map("revised_target")
  progress      String?   // Not Started | In Progress | Complete | Overdue
  sortOrder     Int       @default(0) @map("sort_order")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_agreed_dates")
}

model AuditInformationRequest {
  id           String  @id @default(uuid())
  engagementId String  @map("engagement_id")
  description  String
  isIncluded   Boolean @default(true) @map("is_included")
  sortOrder    Int     @default(0) @map("sort_order")

  engagement AuditEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@map("audit_information_requests")
}

// ─── Client Intelligence ────────────────────────────────────────────────────

model ClientIntelligence {
