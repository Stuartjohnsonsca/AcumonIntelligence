  lastAccessed DateTime @default(now()) @map("last_accessed")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tool_sessions")
}

// ─── IA Feedback Users ─────────────────────────────────────────────────────

model IAFeedbackUser {
