  @@map("risk_chats")
}

model RiskChatMessage {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id")
  role      String   // "user" | "assistant" | "system"
  content   String   @db.Text
  metadata  Json?
  turnOrder Int      @map("turn_order")
  createdAt DateTime @default(now()) @map("created_at")

  chat RiskChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("risk_chat_messages")
}

// ─── Risk Feedback (detailed tester feedback, IAFeedbackUser-gated) ─────────

model RiskFeedback {
  id         String   @id @default(uuid())
  targetType String   @map("target_type") // "chat_message" | "action_plan"
  targetId   String   @map("target_id")
  chatId     String?  @map("chat_id")
  userId     String   @map("user_id")
  firmId     String   @map("firm_id")
  rating     String   // "helpful" | "unhelpful" | "needs_improvement"
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

