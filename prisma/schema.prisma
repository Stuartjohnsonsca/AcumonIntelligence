// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Firm {
  id         String   @id @default(uuid())
  name       String
  dataRegion String   @default("uk") @map("data_region") // uk | eu | us | ap — determines where data is processed and stored
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  users   User[]
  clients Client[]

  @@map("firms")
}

model User {
  id                String    @id @default(uuid())
  firmId            String    @map("firm_id")
  displayId         String    @unique @map("display_id") // e.g. ST001
  name              String
  email             String    @unique
  passwordHash      String    @map("password_hash")
  twoFactorMethod   String    @default("email") @map("two_factor_method")
  isSuperAdmin      Boolean   @default(false) @map("is_super_admin")
  isFirmAdmin       Boolean   @default(false) @map("is_firm_admin")
  isPortfolioOwner  Boolean   @default(false) @map("is_portfolio_owner")
  expiryDate        DateTime? @map("expiry_date")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  firm                  Firm                   @relation(fields: [firmId], references: [id])
  twoFactorCodes        TwoFactorCode[]
  clientAssignments     UserClientAssignment[]
  purchasedSubscriptions Subscription[]
  extractionJobs        ExtractionJob[]
  managedClients        Client[]               @relation("PortfolioManagerClients")
  docSummaryJobs        DocSummaryJob[]

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String   // "Statutory Audit" | "Internal Audit"
  urlPrefix   String   @unique @map("url_prefix")
  expiryDays  Int      @map("expiry_days")
  price1      Float    @map("price_1")
  price5      Float    @map("price_5")
  price10     Float    @map("price_10")
  price20     Float    @map("price_20")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]
  priceChanges  PriceChange[]

  @@map("products")
}

model PriceChange {
  id            String    @id @default(uuid())
  productId     String    @map("product_id")
  effectiveDate DateTime  @map("effective_date")
  price1        Float     @map("price_1")
  price5        Float     @map("price_5")
  price10       Float     @map("price_10")
  price20       Float     @map("price_20")
  committedAt   DateTime  @default(now()) @map("committed_at")
  appliedAt     DateTime? @map("applied_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("price_changes")
}

model Client {
  id                  String   @id @default(uuid())
  firmId              String   @map("firm_id")
  clientName          String   @map("client_name")
  software            String?
  contactName         String?  @map("contact_name")
  contactEmail        String?  @map("contact_email")
  portfolioManagerId  String?  @map("portfolio_manager_id")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  firm                   Firm                    @relation(fields: [firmId], references: [id])
  portfolioManager       User?                   @relation("PortfolioManagerClients", fields: [portfolioManagerId], references: [id], onDelete: SetNull)
  apiKeys                ClientApiKey[]
  subscriptions          Subscription[]
  userAssignments        UserClientAssignment[]
  extractionJobs         ExtractionJob[]
  accountingConnections  AccountingConnection[]
  xeroAuthRequests       XeroAuthRequest[]
  aiUsage                AiUsage[]
  docSummaryJobs         DocSummaryJob[]

  @@map("clients")
}

model ClientApiKey {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  apiKey    String   @unique @map("api_key")
  orgName   String   @map("org_name")
  createdAt DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_api_keys")
}

model Subscription {
  id               String    @id @default(uuid())
  clientId         String    @map("client_id")
  productId        String    @map("product_id")
  purchasedById    String    @map("purchased_by_id")
  quantity         Int
  startDate        DateTime  @map("start_date")
  expiryDate       DateTime  @map("expiry_date")
  stripePaymentId  String?   @map("stripe_payment_id")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  client      Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])
  purchasedBy User    @relation(fields: [purchasedById], references: [id])

  @@map("subscriptions")
}

model UserClientAssignment {
  userId    String   @map("user_id")
  clientId  String   @map("client_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@id([userId, clientId])
  @@map("user_client_assignments")
}

model TwoFactorCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("two_factor_codes")
}

model PendingProductSelection {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  urlPrefix    String   @map("url_prefix")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("pending_product_selections")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

// ─── Access Requests ────────────────────────────────────────────────────────

model AccessRequest {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  clientId      String    @map("client_id")
  token         String    @unique
  status        String    @default("pending") // pending | approved | rejected | expired
  respondedAt   DateTime? @map("responded_at")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("access_requests")
}

// ─── Xero Delegated Auth Requests ───────────────────────────────────────────

model XeroAuthRequest {
  id           String    @id @default(uuid())
  clientId     String    @map("client_id")
  requestedBy  String    @map("requested_by")
  recipientEmail String  @map("recipient_email")
  recipientName  String? @map("recipient_name")
  token        String    @unique
  codeVerifier String?   @map("code_verifier")
  status       String    @default("pending") // pending | authorised | expired
  respondedAt  DateTime? @map("responded_at")
  expiresAt    DateTime  @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("xero_auth_requests")
}

// ─── Accounting System Connections ───────────────────────────────────────────

model AccountingConnection {
  id              String   @id @default(uuid())
  clientId        String   @map("client_id")
  system          String   // "xero" | "sage" | "quickbooks"
  accessToken     String   @map("access_token")
  refreshToken    String   @map("refresh_token")
  tokenExpiresAt  DateTime @map("token_expires_at")
  tenantId        String?  @map("tenant_id")
  orgName         String?  @map("org_name")
  connectedBy     String   @map("connected_by")
  connectedAt     DateTime @default(now()) @map("connected_at")
  expiresAt       DateTime @map("expires_at")
  accountsCache   Json?    @map("accounts_cache")
  accountsCachedAt DateTime? @map("accounts_cached_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, system])
  @@map("accounting_connections")
}

// Temporary storage for Xero OAuth tokens while user picks an organisation
model PendingXeroAuth {
  id             String   @id @default(uuid())
  clientId       String   @map("client_id")
  accessToken    String   @map("access_token")
  refreshToken   String   @map("refresh_token")
  expiresIn      Int      @map("expires_in")
  connectedBy    String   @map("connected_by")
  isDelegated    Boolean  @default(false) @map("is_delegated")
  delegatedToken String?  @map("delegated_token")
  tenants        Json     // Array of { tenantId, tenantName, createdDateUtc }
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("pending_xero_auths")
}

// ─── Data Extraction Tool ────────────────────────────────────────────────────

model ExtractionJob {
  id                   String    @id @default(uuid())
  clientId             String    @map("client_id")
  userId               String    @map("user_id")
  status               String    @default("pending") // pending | processing | complete | failed | expired
  totalFiles           Int       @default(0) @map("total_files")
  processedCount       Int       @default(0) @map("processed_count")
  failedCount          Int       @default(0) @map("failed_count")
  duplicateCount       Int       @default(0) @map("duplicate_count")
  accountingSystem     String?   @map("accounting_system")
  orgName              String?   @map("org_name")
  extractedAt          DateTime? @map("extracted_at")
  expiresAt            DateTime? @map("expires_at")
  reminderSentAt       DateTime? @map("reminder_sent_at")
  finalReminderSentAt  DateTime? @map("final_reminder_sent_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  client    Client              @relation(fields: [clientId], references: [id])
  user      User                @relation(fields: [userId], references: [id])
  files     ExtractionFile[]
  records   ExtractedRecord[]

  @@map("extraction_jobs")
}

model ExtractionFile {
  id            String   @id @default(uuid())
  jobId         String   @map("job_id")
  originalName  String   @map("original_name")
  storagePath   String   @map("storage_path")
  containerName String   @map("container_name")
  fileSize      Int?     @map("file_size")
  mimeType      String?  @map("mime_type")
  wasZipped     Boolean  @default(false) @map("was_zipped")
  zipSourceName String?  @map("zip_source_name")
  status        String   @default("uploaded") // uploaded | processing | extracted | failed | duplicate | expired
  errorMessage  String?  @map("error_message")
  fileHash      String?  @map("file_hash")
  duplicateOfId String?  @map("duplicate_of_id")
  pageCount     Int?     @map("page_count")
  createdAt     DateTime @default(now()) @map("created_at")

  job          ExtractionJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  records      ExtractedRecord[]
  duplicateOf  ExtractionFile?   @relation("FileDuplicates", fields: [duplicateOfId], references: [id])
  duplicates   ExtractionFile[]  @relation("FileDuplicates")

  @@map("extraction_files")
}

model ExtractedRecord {
  id              String   @id @default(uuid())
  jobId           String   @map("job_id")
  fileId          String   @map("file_id")
  referenceId     String   @map("reference_id") // short system-generated ref e.g. DOC-001
  purchaserName   String?  @map("purchaser_name")
  purchaserTaxId  String?  @map("purchaser_tax_id")
  purchaserCountry String? @map("purchaser_country")
  sellerName      String?  @map("seller_name")
  sellerTaxId     String?  @map("seller_tax_id")
  sellerCountry   String?  @map("seller_country")
  documentRef     String?  @map("document_ref")
  documentDate    String?  @map("document_date")
  dueDate         String?  @map("due_date")
  netTotal        Float?   @map("net_total")
  dutyTotal       Float?   @map("duty_total")
  taxTotal        Float?   @map("tax_total")
  grossTotal      Float?   @map("gross_total")
  lineItems       Json?    @map("line_items") // array of {description, quantity, productId, net, tax, duty}
  accountCategory String?  @map("account_category")
  rawExtraction   Json?    @map("raw_extraction")
  fieldLocations  Json?    @map("field_locations")
  createdAt       DateTime @default(now()) @map("created_at")

  job  ExtractionJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  file ExtractionFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@map("extracted_records")
}

model AccountCategoryLearning {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  description String   // the description text pattern
  category    String   // the assigned category
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([clientId, description])
  @@map("account_category_learning")
}

// ─── AI Usage Tracking ──────────────────────────────────────────────────────

model AiUsage {
  id               String   @id @default(uuid())
  clientId         String   @map("client_id")
  jobId            String?  @map("job_id")
  fileId           String?  @map("file_id")
  userId           String   @map("user_id")
  action           String   @default("Financial Data Extraction") // which tool/product triggered the AI call
  model            String   // e.g. "gemini-2.5-flash"
  operation        String   // "extraction" | "categorisation"
  promptTokens     Int      @map("prompt_tokens")
  completionTokens Int      @map("completion_tokens")
  totalTokens      Int      @map("total_tokens")
  estimatedCostUsd Float    @map("estimated_cost_usd")
  createdAt        DateTime @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([clientId, createdAt])
  @@index([userId])
  @@map("ai_usage")
}

// ─── Background Tasks (replaces in-memory task stores) ──────────────────────

model BackgroundTask {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  clientId  String?  @map("client_id")
  type      String   // 'xero-fetch' | 'xero-attachments'
  status    String   @default("running") // running | completed | error
  progress  Json?    // { phase, current, total }
  result    Json?    // task-specific result data
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([createdAt])
  @@map("background_tasks")
}

// ─── Document Summary Tool ──────────────────────────────────────────────────

model DocSummaryJob {
  id             String    @id @default(uuid())
  clientId       String    @map("client_id")
  userId         String    @map("user_id")
  status         String    @default("pending") // pending | processing | complete | failed
  totalFiles     Int       @default(0) @map("total_files")
  processedCount Int       @default(0) @map("processed_count")
  failedCount    Int       @default(0) @map("failed_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  expiresAt      DateTime? @map("expires_at")

  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id])
  files    DocSummaryFile[]
  findings DocSummaryFinding[]

  @@index([clientId])
  @@index([userId])
  @@map("doc_summary_jobs")
}

model DocSummaryFile {
  id            String    @id @default(uuid())
  jobId         String    @map("job_id")
  originalName  String    @map("original_name")
  storagePath   String    @map("storage_path")
  containerName String    @default("upload-inbox") @map("container_name")
  fileSize      Int       @map("file_size")
  mimeType      String    @map("mime_type")
  status        String    @default("uploaded") // uploaded | processing | analysed | failed
  errorMessage  String?   @map("error_message")
  pageCount     Int?      @map("page_count")
  createdAt     DateTime  @default(now()) @map("created_at")

  job      DocSummaryJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  findings DocSummaryFinding[]

  @@index([jobId])
  @@map("doc_summary_files")
}

model DocSummaryFinding {
  id                String   @id @default(uuid())
  jobId             String   @map("job_id")
  fileId            String   @map("file_id")
  area              String   // e.g. "Parties", "Obligations", "Risks", or AI-identified area
  finding           String   @db.Text
  clauseReference   String   @map("clause_reference")
  isSignificantRisk   Boolean  @default(false) @map("is_significant_risk")
  aiSignificantRisk   Boolean  @default(false) @map("ai_significant_risk")
  userResponse      String?  @map("user_response") @db.Text
  accountingImpact  String?  @map("accounting_impact") @db.Text
  auditImpact       String?  @map("audit_impact") @db.Text
  addToTesting      Boolean  @default(false) @map("add_to_testing")
  reviewed          Boolean  @default(false)
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")

  job  DocSummaryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  file DocSummaryFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([fileId])
  @@map("doc_summary_findings")
}

