model MethodologyTestType {
  id           String  @id @default(uuid())
  firmId       String  @map("firm_id")
  name         String // Action name (e.g. "AI Verification", "Request Data")
  code         String
  actionType   String  @default("team_action") @map("action_type") // client_action | ai_action | team_action
  codeSection  String? @map("code_section") // Reference to code/logic section
  executionDef Json?   @map("execution_def") // Execution definition: prompts, templates, inputs, output format
  isActive     Boolean @default(true) @map("is_active")

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@unique([firmId, code])
  @@index([firmId])
  @@map("methodology_test_types")
}

model MethodologyTestBank {
  id         String @id @default(uuid())
  firmId     String @map("firm_id")
  industryId String @map("industry_id")
  fsLine     String @map("fs_line")
  tests      Json // Array of { description: string, testTypeCode: string }
  assertions Json? // Array of applicable assertions

  firm     Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  industry MethodologyIndustry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([firmId, industryId, fsLine])
  @@index([firmId])
  @@index([industryId])
  @@map("methodology_test_banks")
}

model MethodologyTest {
  id              String   @id @default(uuid())
  firmId          String   @map("firm_id")
  name            String
  description     String?  @db.Text
  testTypeCode    String   @map("test_type_code")
  assertions      Json? // ["Completeness", "Existence", ...]
  framework       String   @default("ALL")
  significantRisk Boolean  @default(false) @map("significant_risk") // DEPRECATED — use category instead
  category        String   @default("Normal") @map("category") // Significant Risk | Area of Focus | Normal | Analytical Review | Mandatory
  outputFormat    String?  @map("output_format") // three_section_sampling | three_section_no_sampling | document_summary | spreadsheet
  isIngest        Boolean  @default(false) @map("is_ingest") // Data collection/prep, not an auditable test
  isDraft         Boolean  @default(true) @map("is_draft") // Hidden from engagement audit plans + Plan Customiser; visible only in Test Bank admin
  flow            Json? // { nodes, edges }
  sortOrder       Int      @default(0) @map("sort_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  executionMode String @default("flow") @map("execution_mode") // flow | action_pipeline

  // Declarative schema for the "start-of-test" config modal (e.g. the
  // Year-End Accruals pipeline captures x_days_post_ye here before any
  // action runs). Shape matches ActionDefinition.inputSchema: an array of
  // { code, label, type, required, defaultValue, description, ... }.
  // When set, the runtime prompts the user once and stores the answers on
  // TestExecution.configJson for $ctx.execution.config.<code> access.
  pipelineConfigSchema Json? @map("pipeline_config_schema")

  firm        Firm                        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  allocations MethodologyTestAllocation[]
  actionSteps TestActionStep[]

  @@unique([firmId, name])
  @@index([firmId])
  @@map("methodology_tests")
}

model MethodologyTestAllocation {
  id         String @id @default(uuid())
  testId     String @map("test_id")
  fsLineId   String @map("fs_line_id")
  industryId String @map("industry_id")
  sortOrder  Int    @default(0) @map("sort_order")

  test     MethodologyTest     @relation(fields: [testId], references: [id], onDelete: Cascade)
  fsLine   MethodologyFsLine   @relation(fields: [fsLineId], references: [id], onDelete: Cascade)
  industry MethodologyIndustry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@unique([testId, fsLineId, industryId])
  @@index([fsLineId, industryId])
  @@index([testId])
  @@map("methodology_test_allocations")
}

model MethodologyFsLine {
  id             String  @id @default(uuid())
  firmId         String  @map("firm_id")
  name           String // e.g. "Revenue", "Trade Debtors", "Going Concern"
  lineType       String  @map("line_type") // fs_line_item | note_item
  fsCategory     String  @map("fs_category") // pnl | balance_sheet | cashflow | notes
  sortOrder      Int     @default(0) @map("sort_order")
  isActive       Boolean @default(true) @map("is_active")
  isMandatory    Boolean @default(false) @map("is_mandatory")
  parentFsLineId String? @map("parent_fs_line_id") // note_item links to parent fs_line_item

  firm             Firm                        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  parent           MethodologyFsLine?          @relation("FsLineHierarchy", fields: [parentFsLineId], references: [id], onDelete: SetNull)
  children         MethodologyFsLine[]         @relation("FsLineHierarchy")
  industryMappings MethodologyFsLineIndustry[]
  testAllocations  MethodologyTestAllocation[]
