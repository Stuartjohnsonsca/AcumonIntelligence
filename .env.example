# Supabase / Database
# Replace YOUR-PROJECT-REF with your Supabase project reference (the
# lowercase-alphanumeric string at the start of your project's supabase.co
# hostname). DATABASE_URL uses the pooled (pgbouncer) connection;
# DIRECT_URL uses the direct connection and is what Prisma migrate runs
# DDL against. Both MUST point at the same project — and that project
# MUST be the one your Vercel runtime connects to, otherwise manual SQL
# you run in the Supabase SQL editor won't be visible to the deployed app.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-DB-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:[YOUR-DB-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-SUPABASE-ANON-KEY"

# NextAuth
NEXTAUTH_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"
NEXTAUTH_URL="http://localhost:3000"

# Email (Microsoft Exchange / Office 365)
EMAIL_FROM="agents@acumon.com"
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_USER="agents@acumon.com"
SMTP_PASSWORD="REPLACE_WITH_EXCHANGE_PASSWORD"

# Together AI (document extraction / categorisation)
TOGETHER_API_KEY="REPLACE_WITH_TOGETHER_AI_KEY"
AI_MODEL="meta-llama/Llama-4-Maverick-17B-128E-Instruct-FP8"

# Stripe (placeholder - fill in later)
STRIPE_SECRET_KEY="sk_test_placeholder"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_placeholder"
