{
  "manifest_version": 3,
  "name": "Acumon Screen Capture",
  "version": "1.0.0",
  "description": "One-click screen capture for Acumon Intelligence audit methodology walkthroughs.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://acumon-intelligence.vercel.app/*",
        "*://www.acumonintelligence.com/*",
        "http://localhost/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
